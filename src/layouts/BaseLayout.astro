---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  canonical?: string;
  noindex?: boolean;
  ogImage?: string;
  pageType?: 'website' | 'article';
}

const {
  title,
  description = 'East of England Summit — returning 30 April–1 May 2027. A community-led conference covering Power Apps, Power Automate, Power BI, and Copilot Studio. Based in Norwich, Norfolk.',
  canonical = Astro.url.href,
  noindex = false,
  ogImage = 'https://eoes.co.uk/images/og-card.png',
  pageType = 'website',
} = Astro.props;

const siteName = 'East of England Summit';
const fullTitle = title === 'Home' ? siteName : `${title} | ${siteName}`;

const isHomepage = Astro.url.pathname === '/';
const breadcrumbSchema = !isHomepage ? {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://eoes.co.uk' },
    { '@type': 'ListItem', position: 2, name: title, item: canonical },
  ],
} : null;

const eventSchema = {
  '@context': 'https://schema.org',
  '@type': 'Event',
  name: 'East of England Summit 2027',
  alternateName: 'EoES 2027',
  description: 'The East of England Summit (EoES) — a community-led conference covering Power Apps, Power Automate, Power BI, and Copilot Studio. Returning 30 April–1 May 2027 in Norwich, Norfolk.',
  url: 'https://eoes.co.uk',
  startDate: '2027-04-30',
  endDate: '2027-05-01',
  eventStatus: 'https://schema.org/EventScheduled',
  eventAttendanceMode: 'https://schema.org/OfflineEventAttendanceMode',
  isAccessibleForFree: true,
  inLanguage: 'en-GB',
  location: {
    '@type': 'Place',
    name: 'Central Norwich',
    description: 'Venue to be announced',
    address: {
      '@type': 'PostalAddress',
      addressLocality: 'Norwich',
      addressRegion: 'Norfolk',
      addressCountry: 'GB',
    },
  },
  organizer: {
    '@type': 'Organization',
    name: 'Norfolk Power Platform User Group',
    url: 'https://www.nppug.co.uk',
  },
  image: 'https://eoes.co.uk/images/Logo.png',
  keywords: 'Power Platform, Power Apps, Power Automate, Power BI, Copilot Studio, Microsoft, low-code, Norwich, Norfolk, East of England, conference, summit, 2027',
};
---

<!DOCTYPE html>
<html lang="en-GB">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/png" href="/images/Logo.png" />
    <link rel="preload" as="image" href="/images/Logo.png" />

    <meta name="generator" content={Astro.generator} />

    <!-- Typography -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Archivo+Black&family=Archivo:ital,wght@0,400;0,500;0,600;0,700;0,800;1,400&family=JetBrains+Mono:wght@400;500;600;700&display=swap" rel="stylesheet" />

    <!-- Open Graph -->
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={pageType} />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content="en_GB" />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={`${siteName} — Norwich, Norfolk`} />

    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@eoes" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content={`${siteName} — Norwich, Norfolk`} />

    <title>{fullTitle}</title>

    <script type="application/ld+json" set:html={JSON.stringify(eventSchema)} />
    {breadcrumbSchema && (
      <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    )}

    <!-- Umami Analytics -->
    <script is:inline defer src="https://cloud.umami.is/script.js" data-website-id="9a32fa67-717f-4e5e-a855-ee5ddb7dda91"></script>

    <!-- Google Analytics -->
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-450M6BYX75"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){window.dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-450M6BYX75');
    </script>
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to main content</a>
    <Header />
    <main id="main" role="main">
      <slot />
    </main>
    <Footer />
  </body>
</html>
