---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const speakers = await getCollection('speakers');
  return speakers.map((speaker) => ({
    params: { slug: speaker.slug },
    props: { speaker },
  }));
}

const { speaker } = Astro.props;
const { Content } = await speaker.render();

const initials = speaker.data.name.split(' ').map(n => n[0]).join('').toUpperCase();

// Truncate bio to 155 chars for meta description
const metaDescription = speaker.data.bio.length > 155
  ? speaker.data.bio.slice(0, 152) + '…'
  : speaker.data.bio;

const pageDescription = `${speaker.data.name}${speaker.data.company ? ` from ${speaker.data.company}` : ''} — speaking at the East of England Summit 2026, Norwich. ${metaDescription}`;

// Person JSON-LD
const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: speaker.data.name,
  jobTitle: speaker.data.title,
  ...(speaker.data.company && { worksFor: { '@type': 'Organization', name: speaker.data.company } }),
  ...(speaker.data.image && { image: speaker.data.image }),
  ...(speaker.data.linkedin && { sameAs: [speaker.data.linkedin] }),
  ...(speaker.data.website && { url: speaker.data.website }),
  description: speaker.data.bio,
};
---

<BaseLayout title={speaker.data.name} description={pageDescription.slice(0, 155)}>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(personSchema)} />

  <section class="page-hero" style="padding-bottom: 60px;">
    <div class="bg-year" aria-hidden="true">26</div>
    <span class="spark" style="top: 22%; left: 7%;"></span>
    <div class="container">
      <div class="hero-eyebrow">
        <div class="chip"><span class="dot" style="background: var(--ink-3); box-shadow: 0 0 0 4px rgba(255,255,255,0.08);"></span><span>2026 Speaker</span></div>
      </div>
      <div style="display: flex; flex-direction: column; align-items: flex-start; gap: 24px;">
        <div style="display: flex; flex-wrap: wrap; align-items: flex-end; gap: 28px;">
          <!-- Avatar -->
          {speaker.data.image ? (
            <div style="width: 120px; height: 120px; border-radius: 50%; border: 3px solid rgba(255,255,255,0.15); overflow: hidden; flex-shrink: 0;">
              <img
                src={speaker.data.image}
                alt={speaker.data.name}
                style="width: 100%; height: 100%; object-fit: cover;"
              />
            </div>
          ) : (
            <div style="width: 120px; height: 120px; border-radius: 50%; background: rgba(124,58,237,0.3); border: 3px solid rgba(124,58,237,0.4); display: flex; align-items: center; justify-content: center; font-family: var(--font-display); font-size: 40px; color: var(--ink-0); letter-spacing: -0.04em; flex-shrink: 0;">
              {initials}
            </div>
          )}
          <div>
            {speaker.data.isOrganizer && (
              <div class="chip chip--purple" style="margin-bottom: 12px; display: inline-flex;"><span>Organiser</span></div>
            )}
            <h1 class="display-1 hero-title" style="margin: 0 0 8px;">{speaker.data.name}</h1>
            <p style="font-size: 18px; color: var(--ink-2); margin: 0 0 4px;">{speaker.data.title}</p>
            {speaker.data.company && (
              <p class="mono" style="font-size: 14px; color: var(--ink-3); margin: 0;">{speaker.data.company}</p>
            )}
          </div>
        </div>

        <!-- Social Links -->
        <div class="row" style="gap: 10px; flex-wrap: wrap;">
          {speaker.data.linkedin && (
            <a
              href={speaker.data.linkedin}
              target="_blank"
              rel="noopener noreferrer"
              class="btn btn--ghost btn--sm"
              aria-label={`${speaker.data.name}'s LinkedIn`}
            >
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
              LinkedIn
            </a>
          )}
          {speaker.data.twitter && (
            <a
              href={speaker.data.twitter}
              target="_blank"
              rel="noopener noreferrer"
              class="btn btn--ghost btn--sm"
              aria-label={`${speaker.data.name}'s Twitter/X`}
            >
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
              Twitter / X
            </a>
          )}
          {speaker.data.github && (
            <a
              href={speaker.data.github}
              target="_blank"
              rel="noopener noreferrer"
              class="btn btn--ghost btn--sm"
              aria-label={`${speaker.data.name}'s GitHub`}
            >
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
              GitHub
            </a>
          )}
          {speaker.data.website && (
            <a
              href={speaker.data.website}
              target="_blank"
              rel="noopener noreferrer"
              class="btn btn--ghost btn--sm"
              aria-label={`${speaker.data.name}'s website`}
            >
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9" stroke-linecap="round" stroke-linejoin="round"/></svg>
              Website
            </a>
          )}
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container" style="max-width: 780px;">

      <div class="eyebrow" style="margin-bottom: 18px;">— About —</div>
      <div class="speaker-bio">
        <Content />
      </div>

      {speaker.data.presentations.length > 0 && (
        <div style="margin-top: 48px;">
          <div class="eyebrow" style="margin-bottom: 18px;">— Presentations —</div>
          <div class="stack-4">
            {speaker.data.presentations.map((presentation) => (
              <a
                href={presentation.url}
                target="_blank"
                rel="noopener noreferrer"
                class="card"
                style="display: flex; align-items: center; gap: 16px; padding: 20px 24px; text-decoration: none; transition: border-color 0.2s;"
              >
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="color: var(--yellow); flex-shrink: 0;" aria-hidden="true">
                  <path d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                <div>
                  <div style="font-weight: 600; color: var(--ink-0); font-size: 15px;">{presentation.title}<span class="sr-only"> (opens in new tab)</span></div>
                  {presentation.event && (
                    <div class="mono" style="font-size: 12px; color: var(--ink-3); margin-top: 3px;">{presentation.event}</div>
                  )}
                </div>
              </a>
            ))}
          </div>
        </div>
      )}

      <div style="margin-top: 48px; padding-top: 32px; border-top: 1px solid var(--line-1);">
        <a href="/speakers" class="btn btn--ghost btn--sm">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M15 19l-7-7 7-7" stroke-linecap="round" stroke-linejoin="round"/></svg>
          Back to All Speakers
        </a>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .speaker-bio :global(p) {
    color: var(--ink-2);
    font-size: 16px;
    line-height: 1.75;
    margin-bottom: 1.25em;
  }
  .speaker-bio :global(h2),
  .speaker-bio :global(h3) {
    color: var(--ink-0);
    font-family: var(--font-display);
    letter-spacing: -0.03em;
    margin: 1.5em 0 0.5em;
  }
  .speaker-bio :global(ul),
  .speaker-bio :global(ol) {
    color: var(--ink-2);
    padding-left: 1.5em;
    margin-bottom: 1em;
    line-height: 1.75;
  }
  .speaker-bio :global(a) {
    color: var(--yellow);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .speaker-bio :global(strong) { color: var(--ink-1); }
</style>
