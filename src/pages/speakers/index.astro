---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="2026 Speakers"
  description="Meet the expert Power Platform speakers from EoES 2026 — practitioners from across the East of England and beyond who shared real-world experience with Power Apps, Power Automate, Power BI, and Copilot Studio."
>

<section class="page-hero">
  <div class="bg-year" aria-hidden="true">26</div>
  <span class="spark" style="top: 22%; left: 7%;"></span>
  <span class="spark sm" style="top: 60%; right: 10%;"></span>
  <div class="container">
    <div class="hero-eyebrow"><div class="chip"><span class="dot" style="background: var(--ink-3); box-shadow: 0 0 0 4px rgba(255,255,255,0.08);"></span><span>2026 Archive · Speakers</span></div></div>
    <h1 class="display-1 hero-title" style="max-width: 18ch;">2026 <span class="display-italic">speakers.</span></h1>
    <p class="hero-sub">The inspiring voices from EoES 2026 — practitioners sharing real-world Power Platform experience.</p>
  </div>
  <div class="issue-mark"><b>Vol — 01</b> &nbsp;·&nbsp; 2026 Archive</div>
</section>

<!-- Keynote Speaker -->
<section class="section section--tight">
  <div class="container" style="max-width: 820px;">
    <div class="eyebrow eyebrow--center" style="margin-bottom: 28px; color: var(--yellow);">— Keynote Speaker —</div>
    <article class="card" style="padding: 0; background: linear-gradient(180deg, rgba(251,191,36,0.08) 0%, transparent 60%); border-color: rgba(251,191,36,0.35);">
      <div style="padding: 40px; display: flex; flex-direction: column; align-items: center; text-align: center; gap: 20px;">
        <div style="position: relative;">
          <div style="width: 128px; height: 128px; border-radius: 50%; border: 3px solid rgba(251,191,36,0.5); box-shadow: 0 0 0 8px rgba(251,191,36,0.08), 0 0 40px rgba(251,191,36,0.15); overflow: hidden;">
            <img
              src="/images/speakers/chris-huntingford.jpg"
              alt="Chris Huntingford"
              width="128"
              height="128"
              style="width: 100%; height: 100%; object-fit: cover;"
            />
          </div>
        </div>
        <div>
          <div class="mono" style="color: var(--yellow); font-size: 11px; margin-bottom: 10px; letter-spacing: 0.12em; text-transform: uppercase;">Keynote Speaker · EoES 2026</div>
          <h2 style="font-family: var(--font-display); font-size: clamp(32px, 5vw, 48px); letter-spacing: -0.04em; color: var(--ink-0); line-height: 1; margin-bottom: 16px;">Chris Huntingford</h2>
          <div class="row" style="justify-content: center; gap: 16px; flex-wrap: wrap;">
            <a href="https://www.chrishuntingford.com/" target="_blank" rel="noopener noreferrer" class="btn btn--ghost btn--sm">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" stroke-linecap="round" stroke-linejoin="round"/></svg>
              chrishuntingford.com
            </a>
            <a href="https://www.linkedin.com/in/chrishuntingford/" target="_blank" rel="noopener noreferrer" class="btn btn--ghost btn--sm">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M19 0h-14c-2.76 0-5 2.24-5 5v14c0 2.76 2.24 5 5 5h14c2.76 0 5-2.24 5-5v-14c0-2.76-2.24-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.27c-.97 0-1.75-.79-1.75-1.76s.78-1.76 1.75-1.76 1.75.79 1.75 1.76-.78 1.76-1.75 1.76zm13.5 12.27h-3v-5.6c0-3.37-4-3.11-4 0v5.6h-3v-11h3v1.77c1.4-2.59 7-2.78 7 2.47v6.76z"/></svg>
              LinkedIn
            </a>
          </div>
        </div>
      </div>
    </article>
  </div>
</section>

<!-- Conference Speakers (Sessionize SpeakerWall) -->
<section class="section">
  <div class="container">
    <div class="section-head section-head--center" style="margin-bottom: 40px;">
      <div class="eyebrow eyebrow--center">— Conference Speakers —</div>
      <h2 class="display-3">All 2026<br><span class="display-italic">speakers.</span></h2>
      <p class="sub">Click any speaker to learn more about them and the sessions they presented at EoES 2026.</p>
    </div>
    <link rel="stylesheet" href="https://sessionize.com/api/v2/9q20ek5l/embedstyle" />
    <div class="sessionize-embed">
      <script is:inline src="https://sessionize.com/api/v2/9q20ek5l/view/SpeakerWall"></script>
    </div>
  </div>
</section>

<!-- Modal container required by Sessionize -->
<div id="sz-modal-container" class="is-hidden"></div>

<section class="cta-strip">
  <div class="container center">
    <div class="eyebrow eyebrow--center" style="margin-bottom: 22px;">— EoES Returns —</div>
    <h2 class="display-2" style="max-width: 22ch; margin: 0 auto 22px;">More great speakers<br><span class="display-italic">in 2027.</span></h2>
    <p class="lead muted" style="max-width: 52ch; margin: 0 auto 32px;">Follow us on LinkedIn to be the first to hear about EoES 2027 — speakers, schedule, and how to get involved.</p>
    <div class="row" style="justify-content: center; gap: 12px;">
      <a href="https://www.linkedin.com/company/eoes/" target="_blank" rel="noopener noreferrer" class="btn btn--primary btn--lg">Follow on LinkedIn</a>
      <a href="/sessions" class="btn btn--ghost btn--lg">View 2026 sessions</a>
    </div>
  </div>
</section>

</BaseLayout>
