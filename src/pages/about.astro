---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allSpeakers = await getCollection('speakers');

const findSpeaker = (slug: string) => allSpeakers.find(s => s.slug === slug);
type Speaker = NonNullable<ReturnType<typeof findSpeaker>>;
const notUndefined = (s: Speaker | undefined): s is Speaker => s != null;

const directors = [findSpeaker('duncan-boyne'), findSpeaker('adam-bezance')].filter(notUndefined);
const committee = [
  'sarah-jones', 'stuart-baxter', 'emily-lacey', 'jon-russell',
  'gemma-peck', 'reece-harsley', 'chris-hinchcliffe', 'simon-greenall',
].map(slug => findSpeaker(slug)).filter(notUndefined);

const displayRoles: Record<string, { role: string; company: string }> = {
  'duncan-boyne':      { role: 'Co-Event Director', company: 'CPiO' },
  'adam-bezance':      { role: 'Co-Event Director', company: 'Robiquity' },
  'sarah-jones':       { role: 'Committee',          company: '' },
  'stuart-baxter':     { role: 'Committee',          company: '' },
  'emily-lacey':       { role: 'Committee',          company: '' },
  'jon-russell':       { role: 'Committee',          company: '' },
  'gemma-peck':        { role: 'Co-Founder',         company: 'GTP Tech Recruitment' },
  'reece-harsley':     { role: 'Committee',          company: '' },
  'chris-hinchcliffe': { role: 'Committee',          company: '' },
  'simon-greenall':    { role: 'Committee',          company: '' },
};

const initials = (name: string) => name.split(' ').map(n => n[0]).join('');
---

<BaseLayout
  title="About EoES"
  description="A community-led Power Platform conference in Norwich. Returning 30 April – 1 May 2027. Meet the organising team."
>

<section class="page-hero">
  <div class="bg-year" aria-hidden="true">.</div>
  <span class="spark" style="top: 22%; left: 7%;"></span>
  <span class="spark sm" style="top: 70%; right: 12%;"></span>
  <span class="spark sm" style="top: 38%; right: 22%;"></span>
  <div class="container">
    <div class="hero-eyebrow"><div class="chip chip--cyan"><span class="dot"></span><span>About · 2027</span></div></div>
    <h1 class="display-1 hero-title" style="max-width: 18ch;">A community-led<br><span class="display-italic">Power Platform</span> conference.</h1>
    <p class="hero-sub">EoES — the East of England Summit — is a two-day, community-led conference based in Norwich, organised entirely by volunteers from the Norfolk Power Platform User Group.</p>
  </div>
</section>

<section class="section">
  <div class="container" style="max-width: 980px;">
    <div class="section-head">
      <div class="eyebrow">— Our story —</div>
      <h2 class="display-2">What is EoES?</h2>
    </div>

    <div class="stack-5" style="font-size: 17px; line-height: 1.65; color: var(--ink-2); max-width: 70ch;">
      <p>The East of England Summit (EoES) is a community-led, two-day conference bringing together Power Platform professionals, enthusiasts and newcomers from across the East of England and beyond.</p>
      <p>Organised by the team behind the <a href="https://www.nppug.co.uk" target="_blank" rel="noopener noreferrer" style="color: var(--yellow);">Norfolk Power Platform User Group</a>, EoES provides a larger platform for the region's growing Power Platform community — with hands-on workshops on Friday and a full conference programme on Saturday.</p>
      <p>Whether you're getting started with Power Apps, building complex automation with Power Automate, creating insights with Power BI, or exploring Copilot Studio — there's something at EoES for you.</p>
    </div>

    <div class="grid-2" style="margin-top: 56px;">
      <article class="card">
        <span class="card-num">01</span>
        <h3 class="card-title">Your two days</h3>
        <ul style="list-style: none; padding: 0; margin: 16px 0 0; display: flex; flex-direction: column; gap: 10px;">
          <li style="display: flex; gap: 10px; color: var(--ink-2); font-size: 15px; line-height: 1.55;"><span style="color: var(--yellow);">+</span> Friday workshop day: choose a hands-on workshop and build something real</li>
          <li style="display: flex; gap: 10px; color: var(--ink-2); font-size: 15px; line-height: 1.55;"><span style="color: var(--yellow);">+</span> Saturday conference: full programme with parallel tracks and a keynote</li>
          <li style="display: flex; gap: 10px; color: var(--ink-2); font-size: 15px; line-height: 1.55;"><span style="color: var(--yellow);">+</span> Talks from practitioners who work with Power Platform every day in real businesses</li>
          <li style="display: flex; gap: 10px; color: var(--ink-2); font-size: 15px; line-height: 1.55;"><span style="color: var(--yellow);">+</span> Saturday exhibition area with sponsors and vendors to browse during breaks</li>
          <li style="display: flex; gap: 10px; color: var(--ink-2); font-size: 15px; line-height: 1.55;"><span style="color: var(--yellow);">+</span> A friendly, inclusive atmosphere — no experience required to get value</li>
        </ul>
      </article>

      <article class="card">
        <span class="card-num">02</span>
        <h3 class="card-title">Who's coming</h3>
        <ul style="list-style: none; padding: 0; margin: 16px 0 0; display: flex; flex-direction: column; gap: 10px;">
          <li style="display: flex; gap: 10px; color: var(--ink-2); font-size: 15px; line-height: 1.55;"><span style="color: var(--pink);">+</span> Power Platform users from East of England organisations</li>
          <li style="display: flex; gap: 10px; color: var(--ink-2); font-size: 15px; line-height: 1.55;"><span style="color: var(--pink);">+</span> Developers curious about low-code, pro-code and everything in between</li>
          <li style="display: flex; gap: 10px; color: var(--ink-2); font-size: 15px; line-height: 1.55;"><span style="color: var(--pink);">+</span> Business analysts and IT leaders evaluating Power Platform</li>
          <li style="display: flex; gap: 10px; color: var(--ink-2); font-size: 15px; line-height: 1.55;"><span style="color: var(--pink);">+</span> Students and career-changers exploring the Microsoft ecosystem</li>
          <li style="display: flex; gap: 10px; color: var(--ink-2); font-size: 15px; line-height: 1.55;"><span style="color: var(--pink);">+</span> NPPUG regulars ready to experience the community at summit scale</li>
        </ul>
      </article>
    </div>

    <div class="stats" style="margin-top: 56px;">
      <div class="stat"><div class="num yellow">2</div><div class="label">Full Days</div></div>
      <div class="stat"><div class="num">Free</div><div class="label">Conference Day (Sat)</div></div>
      <div class="stat"><div class="num" style="color: var(--pink);">Norwich</div><div class="label">East of England</div></div>
      <div class="stat"><div class="num" style="color: var(--cyan);">2027</div><div class="label">30 April – 1 May</div></div>
    </div>
  </div>
</section>

<section class="section">
  <div class="container">
    <div class="section-head section-head--center">
      <div class="eyebrow eyebrow--center">— Meet the Team —</div>
      <h2 class="display-2">Volunteers,<br><span class="display-italic">all the way down.</span></h2>
      <p class="sub">EoES is organised entirely by volunteers from the Norfolk Power Platform User Group community.</p>
    </div>

    <div class="mono" style="text-align: center; margin-bottom: 24px; color: var(--yellow);">— Co-Event Directors —</div>
    <div class="grid-2" style="margin-bottom: 64px;">
      {directors.map((person) => {
        const { role, company } = displayRoles[person.slug];
        return (
          <article class="speaker-tile" style="display: grid; grid-template-columns: 200px 1fr;">
            <div class="photo">
              {person.data.image
                ? <img src={person.data.image} alt={person.data.name} loading="lazy" />
                : <div style={`display:grid;place-items:center;background:linear-gradient(180deg,var(--purple-soft),var(--surface-2));`}><div style="font-family:var(--font-display);font-size:48px;color:var(--ink-0);">{initials(person.data.name)}</div></div>
              }
            </div>
            <div class="meta" style="padding: 22px;">
              <span class="role" style="color: var(--yellow);">{role}</span>
              <h3 class="name" style="font-size: 22px; margin-bottom: 4px;">{person.data.name}</h3>
              {company && <div class="company">{company}</div>}
            </div>
          </article>
        );
      })}
    </div>

    <hr class="divider" />

    <div class="mono" style="text-align: center; margin-bottom: 24px; color: var(--pink);">— Organising Committee —</div>
    <div class="grid-4">
      {committee.map((person) => {
        const { role, company } = displayRoles[person.slug];
        const hasPhoto = Boolean(person.data.image);
        const gradients = {
          'emily-lacey':     'linear-gradient(180deg,var(--purple-soft),var(--surface-2))',
          'reece-harsley':   'linear-gradient(180deg,var(--pink-soft),var(--surface-2))',
          'chris-hinchcliffe': 'linear-gradient(180deg,var(--cyan-soft),var(--surface-2))',
        };
        const fallbackGradient = gradients[person.slug] ?? 'linear-gradient(180deg,var(--purple-soft),var(--surface-2))';
        return (
          <article class="speaker-tile">
            <div class="photo">
              {hasPhoto
                ? <img src={person.data.image} alt={person.data.name} loading="lazy" />
                : <div style={`display:grid;place-items:center;background:${fallbackGradient};`}><div style="font-family:var(--font-display);font-size:48px;color:var(--ink-0);">{initials(person.data.name)}</div></div>
              }
            </div>
            <div class="meta">
              <span class="role">Committee</span>
              <h3 class="name">{person.data.name}</h3>
              {company && <div class="company">{company}</div>}
            </div>
          </article>
        );
      })}
    </div>
  </div>
</section>

<section class="section section--tight">
  <div class="container">
    <div class="frame-panel center" style="max-width: 920px; margin: 0 auto;">
      <div class="eyebrow eyebrow--center" style="margin-bottom: 22px;">— Powered by —</div>
      <h2 class="display-3" style="margin-bottom: 22px;">About <span class="display-italic">NPPUG.</span></h2>
      <p class="lead muted" style="max-width: 60ch; margin: 0 auto 32px;">EoES is organised by the Norfolk Power Platform User Group — a community of Microsoft Power Platform enthusiasts based in Norwich and Norfolk who run monthly meetups throughout the year.</p>
      <a href="https://www.nppug.co.uk" target="_blank" rel="noopener noreferrer" class="btn btn--primary btn--lg">
        Visit nppug.co.uk
        <svg class="arrow" viewBox="0 0 24 24"><path d="M5 12h14M13 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </a>
    </div>
  </div>
</section>

<section class="cta-strip">
  <div class="container center">
    <div class="eyebrow eyebrow--center" style="margin-bottom: 22px;">— Stay Connected —</div>
    <h2 class="display-2" style="max-width: 22ch; margin: 0 auto 22px;">EoES returns<br><span class="display-italic">30 Apr – 1 May 2027.</span></h2>
    <p class="lead muted" style="max-width: 56ch; margin: 0 auto 36px;">Follow us on LinkedIn for announcements on dates, speakers, and how to get involved.</p>
    <div class="row" style="justify-content: center; gap: 12px;">
      <a href="https://www.linkedin.com/company/eoes/" target="_blank" rel="noopener noreferrer" class="btn btn--primary btn--lg">Follow on LinkedIn</a>
      <a href="/sponsorship" class="btn btn--ghost btn--lg">Become a sponsor</a>
    </div>
  </div>
</section>

</BaseLayout>
