---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="2027 Sponsors"
  description="The organisations making EoES 2027 possible."
>

<section class="page-hero">
  <div class="bg-year" aria-hidden="true">+</div>
  <span class="spark" style="top: 22%; left: 7%;"></span>
  <span class="spark sm" style="top: 60%; right: 10%;"></span>
  <div class="container">
    <div class="hero-eyebrow"><div class="chip chip--yellow"><span class="dot"></span><span>Sponsors · 2027</span></div></div>
    <h1 class="display-1 hero-title" style="max-width: 16ch;">Sponsors <span class="display-italic">2027.</span></h1>
    <p class="hero-sub">The organisations making EoES 2027 possible. More to be announced — five tiers from £250 to £6,000, an exclusive Recruitment Partner package, and five add-ons.</p>
  </div>
</section>

<section class="section">
  <div class="container" style="max-width: 880px;">
    <div class="eyebrow eyebrow--center" style="margin-bottom: 18px;">— Silver Sponsor · 2027 —</div>
    <article class="card" style="border-color: rgba(148,163,184,0.45); padding: 0; background: linear-gradient(180deg, rgba(148,163,184,0.10) 0%, transparent 100%); margin-bottom: 56px;">
      <div style="background: #fff; height: 140px; display: grid; place-items: center; padding: 24px; border-radius: 22px 22px 0 0;">
        <img src="/images/sponsors/iThink365.png" alt="iThink365" loading="lazy" style="max-height: 100%; max-width: 80%;">
      </div>
      <div style="padding: 32px; text-align: center;">
        <h3 class="h3" style="font-size: 22px; margin-bottom: 12px;">iThink365</h3>
        <p class="muted" style="margin-bottom: 24px;">Microsoft 365 and SharePoint specialists, building products and consultancy that help organisations get more out of the tools they already have.</p>
        <a href="https://ithink365.co.uk/" target="_blank" rel="noopener noreferrer" class="btn btn--primary">Visit ithink365.co.uk</a>
      </div>
    </article>

    <div class="frame-panel center">
      <div class="eyebrow eyebrow--center" style="margin-bottom: 18px;">— More to come —</div>
      <h2 class="display-3" style="margin-bottom: 18px;">More 2027 sponsors<br><span class="display-italic">announce soon.</span></h2>
      <p class="lead muted" style="max-width: 56ch; margin: 0 auto 32px;">If you'd like your organisation listed here, get in touch about our 2027 packages.</p>
      <a href="mailto:info@eoepps.co.uk?subject=Sponsorship%20Enquiry%20-%20EoES%202027" class="btn btn--primary btn--lg">
        Become a 2027 sponsor
        <svg class="arrow" viewBox="0 0 24 24"><path d="M5 12h14M13 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </a>
    </div>

    <div class="center" style="margin-top: 56px;">
      <p class="muted">Looking for 2026 sponsors?</p>
      <a href="/sponsors/2026" class="mono" style="color: var(--yellow); margin-top: 12px; display: inline-block;">View 2026 Sponsors →</a>
    </div>
  </div>
</section>

<section class="cta-strip">
  <div class="container center">
    <div class="eyebrow eyebrow--center" style="margin-bottom: 22px;">— Support the community —</div>
    <h2 class="display-2" style="max-width: 22ch; margin: 0 auto 22px;">Put your brand<br><span class="display-italic">in front of the East.</span></h2>
    <p class="lead muted" style="max-width: 56ch; margin: 0 auto 36px;">Sponsoring EoES puts your brand in front of Microsoft professionals from across the region.</p>
    <a href="/sponsorship" class="btn btn--primary btn--lg">View 2027 packages</a>
  </div>
</section>

</BaseLayout>
