---
import BaseLayout from '../layouts/BaseLayout.astro';

const TICKETING_URL = 'https://EoEStickets.netlify.app';
---

<BaseLayout
  title="Workshops"
  description="Hands-on Power Platform workshops at EoES 2026 - a full day of instructor-led sessions covering Power Apps, Power Automate, Power BI, and Copilot Studio. Friday 30 April 2026, Norwich."
>

<section class="page-hero">
  <div class="bg-year" aria-hidden="true">01</div>
  <span class="spark" style="top: 22%; left: 7%;"></span>
  <span class="spark sm" style="top: 60%; right: 10%;"></span>
  <div class="container">
    <div class="hero-eyebrow"><div class="chip chip--yellow"><span class="dot"></span><span>Workshop Day - 2026 - Ticketed</span></div></div>
    <h1 class="display-1 hero-title" style="max-width: 16ch;">Hands-on<br>workshops.<br><span class="display-italic">Day one.</span></h1>
    <p class="hero-sub">Friday 30 April 2026 - The Digital Hub, Norwich. Small-group, instructor-led workshops - bring your laptop.</p>
  </div>
  <div class="issue-mark"><b>Vol - 01</b> &nbsp;-&nbsp; Workshop Day</div>
</section>

<section class="section">
  <div class="container">
    <div class="frame-panel" style="display: flex; flex-wrap: wrap; gap: 24px; align-items: center; justify-content: space-between; margin-bottom: 48px;">
      <div>
        <div class="eyebrow" style="margin-bottom: 8px;">- Hands-on learning - Day 01 -</div>
        <h2 class="h3" style="margin-bottom: 4px;">Small-group workshops with expert facilitators.</h2>
        <p class="muted" style="margin: 0; font-size: 14px;">Bring your laptop and get ready to build.</p>
      </div>
      <a href={TICKETING_URL} target="_blank" rel="noopener noreferrer" class="btn btn--primary" style="flex-shrink: 0;">
        Book your place
        <svg class="arrow" viewBox="0 0 24 24"><path d="M5 12h14M13 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </a>
    </div>

    <div style="padding: 48px 0;">
      <div class="frame-panel center" style="max-width: 560px; margin: 0 auto;">
        <div class="eyebrow eyebrow--center" style="margin-bottom: 14px;">- Coming soon -</div>
        <h3 class="display-3" style="margin-bottom: 14px;">Workshops announced<br><span class="display-italic">shortly.</span></h3>
        <p class="muted" style="max-width: 48ch; margin: 0 auto 24px;">Follow us on LinkedIn to be the first to know when workshops are confirmed.</p>
        <a href="https://www.linkedin.com/company/eoes/" target="_blank" rel="noopener noreferrer" class="btn btn--primary">Follow on LinkedIn</a>
      </div>
    </div>
  </div>
</section>

<section class="cta-strip">
  <div class="container center">
    <div class="eyebrow eyebrow--center" style="margin-bottom: 22px;">- Secure your place -</div>
    <h2 class="display-2" style="max-width: 20ch; margin: 0 auto 22px;">Ready to<br><span class="display-italic">learn?</span></h2>
    <p class="lead muted" style="max-width: 48ch; margin: 0 auto 32px;">Register on the ticketing app to secure your place at a workshop.</p>
    <a href={TICKETING_URL} target="_blank" rel="noopener noreferrer" class="btn btn--primary btn--lg">
      Go to ticketing app
      <svg class="arrow" viewBox="0 0 24 24"><path d="M5 12h14M13 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </a>
  </div>
</section>

</BaseLayout>
