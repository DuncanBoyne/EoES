---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Workshops"
  description="Hands-on Microsoft workshops at EoES 2027 — a full day of small-group, instructor-led sessions in central Norwich. Friday 30 April 2027."
>

<section class="page-hero">
  <div class="bg-year" aria-hidden="true">01</div>
  <span class="spark" style="top: 22%; left: 7%;"></span>
  <span class="spark sm" style="top: 60%; right: 10%;"></span>
  <div class="container">
    <div class="hero-eyebrow"><div class="chip chip--yellow"><span class="dot"></span><span>Workshop Day · 2027 · Ticketed</span></div></div>
    <h1 class="display-1 hero-title" style="max-width: 16ch;">Hands-on<br>workshops.<br><span class="display-italic">Day one.</span></h1>
    <p class="hero-sub">Friday 30 April 2027 — central Norwich, venue announced soon. Small-group, instructor-led workshops where you actually build. Bring your laptop.</p>
  </div>
</section>

<section class="section">
  <div class="container">
    <div class="frame-panel" style="display: flex; flex-wrap: wrap; gap: 24px; align-items: center; justify-content: space-between; margin-bottom: 48px;">
      <div>
        <div class="eyebrow" style="margin-bottom: 8px;">— Hands-on learning · Day 01 —</div>
        <h2 class="h3" style="margin-bottom: 4px;">Small-group workshops with expert facilitators.</h2>
        <p class="muted" style="margin: 0; font-size: 14px;">09:00 — 16:30 · Paid ticket · Limited places · Lunch included.</p>
      </div>
      <a href="https://www.linkedin.com/company/eoes/" target="_blank" rel="noopener noreferrer" class="btn btn--primary" style="flex-shrink: 0;">
        Follow for ticket news<span class="sr-only"> (opens in new tab)</span>
        <svg class="arrow" viewBox="0 0 24 24"><path d="M5 12h14M13 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </a>
    </div>

    <div style="padding: 48px 0;">
      <div class="frame-panel center" style="max-width: 560px; margin: 0 auto;">
        <div class="eyebrow eyebrow--center" style="margin-bottom: 14px;">— Coming soon —</div>
        <h3 class="display-3" style="margin-bottom: 14px;">2027 workshops<br><span class="display-italic">announced shortly.</span></h3>
        <p class="muted" style="max-width: 48ch; margin: 0 auto 24px;">Workshop topics, speakers and tickets for EoES 2027 will be announced on LinkedIn first — along with the Day 1 venue.</p>
        <a href="https://www.linkedin.com/company/eoes/" target="_blank" rel="noopener noreferrer" class="btn btn--primary">Follow on LinkedIn</a>
      </div>
    </div>
  </div>
</section>

<section class="cta-strip">
  <div class="container center">
    <div class="eyebrow eyebrow--center" style="margin-bottom: 22px;">— Plan your two days —</div>
    <h2 class="display-2" style="max-width: 20ch; margin: 0 auto 22px;">Ready to<br><span class="display-italic">learn?</span></h2>
    <p class="lead muted" style="max-width: 48ch; margin: 0 auto 32px;">Workshops on Friday, free conference day on Saturday. See how the two days fit together.</p>
    <div class="row" style="justify-content: center; gap: 12px;">
      <a href="/schedule" class="btn btn--primary btn--lg">View the schedule</a>
      <a href="/why-attend" class="btn btn--ghost btn--lg">Why attend</a>
    </div>
  </div>
</section>

</BaseLayout>
