---
import BaseLayout from '../layouts/BaseLayout.astro';

const tiers = [
  { key: 'friend', name: 'Friend', price: '£250', availability: '', className: 'tier-friend' },
  { key: 'community', name: 'Community', price: '£750', availability: '', className: 'tier-community' },
  { key: 'silver', name: 'Silver', price: '£1,500', availability: '5 of 6 available', className: 'tier-silver' },
  { key: 'gold', name: 'Gold', price: '£3,500', availability: '3 available', className: 'tier-gold' },
  { key: 'platinum', name: 'Platinum', price: '£6,000', availability: '1 available', className: 'tier-platinum' },
] as const;

const comparisonSections = [
  {
    group: 'Brand & Logo',
    rows: [
      ['Website logo placement', 'Grouped panel', true, true, true, true],
      ['Rotating sponsor slides', 'Shared slide', true, true, true, true],
      ['Logo on venue roller banners', false, false, false, true, true],
      ['Headline logo placement alongside EoES branding', false, false, false, false, true],
      ['Exclusive branding on attendee lanyards', false, false, false, false, true],
    ],
  },
  {
    group: 'Social Media',
    rows: [
      ['Sponsor recognition and visibility', false, true, true, true, true],
      ['Featured on at least 50% of build-up posts', false, false, false, false, true],
    ],
  },
  {
    group: 'Video & Keynote',
    rows: [
      ['1-minute video during keynote reel', false, true, true, true, true],
      ['Additional video on venue screens throughout the day', false, true, true, true, true],
      ['Logo size on rotating sponsor slides', 'Grouped', 'Standard', 'Prominent', 'Featured', 'Headline'],
    ],
  },
  {
    group: 'Expo Hall',
    rows: [
      ['Expo hall presence', false, false, true, true, true],
      ['Expo space', null, null, '2m x 2m', '3m x 3m', '4m x 4m'],
      ['Expo hall positioning', null, null, 'Standard', 'Premium', 'First choice'],
    ],
  },
  {
    group: 'Sponsored Session',
    rows: [
      ['Sponsored session', false, false, '1 x 15 min conference track', '2 x 15 min conference track', '45 min auditorium slot'],
      ['Up to 20% promotional / sales content', false, false, true, true, true],
    ],
  },
  {
    group: 'Attendee Engagement',
    rows: [
      ['Workshop tickets', false, false, '1 ticket', '2 tickets', '4 tickets'],
      ['Attendee information access', false, false, 'Post-event', 'Post-event', 'Early access'],
    ],
  },
  {
    group: 'Attendee Bags',
    rows: [
      ['Branded item in attendee bags', true, true, true, true, true],
    ],
  },
] as const;

const reasons = [
  {
    tone: 'yellow',
    title: 'Promote your brand',
    text: 'Reach a targeted audience of Microsoft professionals, decision-makers, and innovators from across the East of England.',
  },
  {
    tone: 'pink',
    title: 'Showcase your expertise',
    text: "Position your brand at the centre of the East of England's fast-growing Microsoft community.",
  },
  {
    tone: 'cyan',
    title: 'Support the community',
    text: 'Demonstrate your commitment to the local tech community. EoES is built by volunteers, and sponsorship is what makes it possible.',
  },
  {
    tone: 'purple',
    title: 'Network directly',
    text: 'Exhibition stands on Day 2 give you direct access to attendees, potential clients, partners, and candidates.',
  },
] as const;

const audiences = [
  {
    title: 'The audience',
    items: [
      'Microsoft professionals from across the East of England',
      'Developers, analysts, and IT decision-makers',
      'Two full days of direct engagement',
    ],
  },
  {
    title: 'On the day',
    items: [
      'Exhibition area at the conference venue on Day 2',
      'Your logo on event slides throughout both days',
      'Verbal recognition in opening and closing remarks',
    ],
  },
  {
    title: 'Beyond the event',
    items: [
      'Your logo on the EoES website throughout the event year',
      'Social media promotion to the EoES community and beyond',
      "Association with the East of England's Microsoft community event",
    ],
  },
] as const;

const addOns = [
  {
    title: 'Workshop Day',
    price: '£1,000',
    text: 'The workshop day is presented by your company, with your brand name attached to Day 1 across event materials and communications.',
  },
  {
    title: 'Summit Lunch',
    price: '£1,000',
    text: 'Sponsor the conference day lunch. Your brand is recognised across signage, slides, and announcements on the day.',
  },
  {
    title: 'T-shirt Sponsor',
    price: '£1,000',
    text: 'Your logo appears on the official EoES t-shirts worn by speakers and staff throughout both days of the event.',
  },
  {
    title: 'Speaker Dinner',
    price: '£1,500',
    text: 'The night before the conference, our speakers, MVPs, and community leaders sit down together, and your brand hosts the table. Recognition throughout the dinner, and a couple of seats at it.',
  },
  {
    title: 'End of Day Drinks',
    price: '£1,000',
    text: 'When the sessions wrap and the room relaxes, the real conversations start. Signage, recognition, and your logo attached to the moment everyone remembers.',
  },
] as const;

const tierDetails = [
  {
    className: 'tier-detail--platinum',
    name: 'Platinum Sponsor',
    price: '£6,000',
    meta: '1 available',
    badge: 'Exclusive Headline Sponsor',
    text: 'The exclusive headline partnership tier for organisations wanting maximum visibility, premium event presence, and direct engagement with the Microsoft community ecosystem.',
  },
  {
    className: 'tier-detail--gold',
    name: 'Gold Sponsor',
    price: '£3,500',
    meta: '3 available',
    badge: '',
    text: 'A strong and highly visible presence with premium expo positioning, enhanced branding opportunities, attendee engagement, and direct access to the Microsoft community ecosystem.',
  },
  {
    className: 'tier-detail--silver',
    name: 'Silver Sponsor',
    price: '£1,500',
    meta: '5 of 6 available',
    badge: '',
    text: 'A visible and engaging presence with expo hall access, event branding opportunities, and direct interaction with attendees throughout the conference.',
  },
  {
    className: 'tier-detail--community',
    name: 'Community Sponsor',
    price: '£750',
    meta: '',
    badge: '',
    text: 'For organisations, creators, training providers, conferences, and community-focused businesses who want to support EoES while gaining visibility within the Microsoft ecosystem.',
  },
  {
    className: 'tier-detail--friend',
    name: 'Friend of EoES',
    price: '£250',
    meta: '',
    badge: '',
    text: 'An entry-level tier for local businesses, freelancers, podcasters, creators, and community supporters who want to back EoES 2027.',
  },
] as const;

const recruitmentPartner = {
  name: 'Recruitment Partner',
  price: '£5,000',
  meta: '1 available · Exclusive',
  badge: 'Official Talent Partner',
  intro: 'One recruitment or talent business owns hiring at EoES 2027. No competing agencies on site, and no shared spotlight. A single mid-level Microsoft hire through an agency costs an employer £8,000 to £10,000 in fees on a £40,000 salary, so this package is less than one placement.',
  includes: [
    'Category exclusivity as the sole recruitment and talent partner. No other agency can sponsor or exhibit.',
    'Official Talent Partner billing across the website, event slides, and social throughout the campaign.',
    'Premium expo hall stand, 3m x 3m, with premium positioning.',
    'A dedicated careers-focused session or panel.',
    'Opt-in candidate access. An "open to opportunities" list of attendees who want to hear from you, collected in a GDPR-compliant way.',
    'Podcast invite, plus the full brand package: website, banners, keynote reel video, branded item in attendee bags, and 50% or more of build-up posts.',
    'Two workshop tickets, and early access to attendee information.',
  ],
} as const;

function cellLabel(value: boolean | string | null) {
  if (value === true) return 'Included';
  if (value === false) return 'Not included';
  if (value === null) return 'Not applicable';
  return value;
}
---

<BaseLayout
  title="Become a Sponsor"
  description="Sponsor EoES 2027 and put your brand in front of Microsoft professionals, developers, and decision-makers from across the East of England."
>

<section class="page-hero">
  <div class="bg-year" aria-hidden="true">£</div>
  <span class="spark" style="top: 22%; left: 7%;"></span>
  <span class="spark sm" style="top: 60%; right: 10%;"></span>
  <div class="container">
    <div class="hero-eyebrow"><div class="chip chip--yellow"><span class="dot"></span><span>Sponsorship · 2027</span></div></div>
    <h1 class="display-1 hero-title" style="max-width: 18ch;">Sponsor<br><span class="display-italic">EoES 2027.</span></h1>
    <p class="hero-sub">Five tiers from £250 to £6,000, an exclusive Recruitment Partner package, and five add-ons. Put your brand in front of Microsoft professionals from across the East of England.</p>
  </div>
</section>

<section class="section">
  <div class="container">
    <div class="section-head section-head--center">
      <div class="eyebrow eyebrow--center">— Why sponsor —</div>
      <h2 class="display-3">Four reasons to<br><span class="display-italic">partner with us.</span></h2>
    </div>

    <div class="grid-2">
      {reasons.map(reason => (
        <article class="card">
          <div class:list={['card-icon', reason.tone]} aria-hidden="true">+</div>
          <h3 class="card-title">{reason.title}</h3>
          <p class="card-body">{reason.text}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<section class="section section--tight">
  <div class="container">
    <div class="section-head section-head--center">
      <div class="eyebrow eyebrow--center">— Your audience —</div>
      <h2 class="display-3">Who you'll<br><span class="display-italic">reach.</span></h2>
    </div>

    <div class="grid-3">
      {audiences.map((audience, index) => (
        <article class="card" style="text-align: center;">
          <div class:list={['card-icon', ['yellow', 'pink', 'cyan'][index]]} style="margin: 0 auto 16px;" aria-hidden="true">+</div>
          <h3 class="card-title">{audience.title}</h3>
          <ul class="muted clean-list">
            {audience.items.map(item => <li>{item}</li>)}
          </ul>
        </article>
      ))}
    </div>
  </div>
</section>

<section class="section">
  <div class="container">
    <div class="section-head section-head--center">
      <div class="eyebrow eyebrow--center">— 2027 Packages —</div>
      <h2 class="display-3">Compare all<br><span class="display-italic">packages.</span></h2>
      <p class="sub">Support EoES 2027 and put your brand in front of Microsoft professionals from across the East of England.</p>
    </div>

    <div class="editorial-table-wrap">
      <table class="editorial-table">
        <caption class="sr-only">Sponsorship package comparison</caption>
        <thead>
          <tr>
            <th scope="col">Benefit</th>
            {tiers.map(tier => (
              <th scope="col" class={tier.className}>
                <span class="tier-name">{tier.name}</span>
                <span class="tier-price">{tier.price}</span>
                {tier.availability && <span class="tier-avail">{tier.availability}</span>}
              </th>
            ))}
          </tr>
        </thead>
        <tbody>
          {comparisonSections.map(section => (
            <>
              <tr class="group-row"><td colspan="6">{section.group}</td></tr>
              {section.rows.map(row => (
                <tr>
                  <th scope="row">{row[0]}</th>
                  {row.slice(1).map(value => (
                    <td>
                      {value === true ? (
                        <>
                          <span class="sr-only">Included</span>
                          <span class="yes" aria-hidden="true">✓</span>
                        </>
                      ) : value === false ? (
                        <>
                          <span class="sr-only">Not included</span>
                          <span class="no" aria-hidden="true">×</span>
                        </>
                      ) : value === null ? (
                        <>
                          <span class="sr-only">Not applicable</span>
                          <span class="no" aria-hidden="true">—</span>
                        </>
                      ) : (
                        <span class="cell-mono" aria-label={cellLabel(value)}>{value}</span>
                      )}
                    </td>
                  ))}
                </tr>
              ))}
            </>
          ))}
        </tbody>
      </table>
    </div>
  </div>
</section>

<section class="section section--tight">
  <div class="container" style="max-width: 900px;">
    <div class="section-head section-head--center">
      <div class="eyebrow eyebrow--center">— Exclusive —</div>
      <h2 class="display-3">The only recruiter<br><span class="display-italic">in the room.</span></h2>
    </div>

    <article class="card tier-detail tier-detail--recruitment">
      <div class="tier-detail-head">
        <div>
          <div class="mono tier-detail-name">{recruitmentPartner.name}</div>
          <div class="tier-detail-price">{recruitmentPartner.price}</div>
          <div class="mono tier-detail-meta">{recruitmentPartner.meta}</div>
        </div>
        <div class="tier-detail-badge">{recruitmentPartner.badge}</div>
      </div>
      <div class="recruitment-body">
        <p class="muted" style="line-height: 1.75; margin: 0 0 24px;">{recruitmentPartner.intro}</p>
        <ul class="clean-list recruitment-list">
          {recruitmentPartner.includes.map(item => <li>{item}</li>)}
        </ul>
      </div>
    </article>
  </div>
</section>

<section class="section section--tight">
  <div class="container">
    <div class="section-head section-head--center">
      <div class="eyebrow eyebrow--center">— Premium add-ons —</div>
      <h2 class="display-3">Sponsorship<br><span class="display-italic">add-ons.</span></h2>
      <p class="sub">Available with any sponsorship tier. From £1,000. One of each available.</p>
    </div>

    <div class="grid-3">
      {addOns.map(addOn => (
        <article class="card addon-card">
          <div class="row" style="justify-content: space-between; gap: 16px; margin-bottom: 16px;">
            <div class="chip chip--purple" style="margin: 0;"><span>Add-on</span></div>
            <div style="text-align: right;">
              <div class="addon-price">{addOn.price}</div>
              <div class="mono" style="font-size: 11px; color: var(--ink-3);">1 available</div>
            </div>
          </div>
          <h3 class="h3" style="margin-bottom: 10px;">{addOn.title}</h3>
          <p class="muted" style="font-size: 14px; line-height: 1.7;">{addOn.text}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<section class="section section--tight">
  <div class="container" style="max-width: 900px;">
    <div class="section-head section-head--center">
      <div class="eyebrow eyebrow--center">— Tier details —</div>
      <h2 class="display-3">What's included<br><span class="display-italic">at each level.</span></h2>
    </div>

    <div class="stack-6">
      {tierDetails.map(tier => (
        <article class:list={['card', 'tier-detail', tier.className]}>
          <div class="tier-detail-head">
            <div>
              <div class="mono tier-detail-name">{tier.name}</div>
              <div class="tier-detail-price">{tier.price}</div>
              {tier.meta && <div class="mono tier-detail-meta">{tier.meta}</div>}
            </div>
            {tier.badge && <div class="tier-detail-badge">{tier.badge}</div>}
          </div>
          <p class="muted" style="line-height: 1.75; margin: 0;">{tier.text}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<section class="cta-strip">
  <div class="container center">
    <div class="eyebrow eyebrow--center" style="margin-bottom: 22px;">— Get in touch —</div>
    <h2 class="display-2" style="max-width: 22ch; margin: 0 auto 22px;">Ready to<br><span class="display-italic">sponsor EoES?</span></h2>
    <p class="lead muted" style="max-width: 52ch; margin: 0 auto 32px;">Get in touch and we'll send you the full sponsorship prospectus.</p>
    <div class="row" style="justify-content: center; gap: 12px;">
      <a href="mailto:info@eoepps.co.uk?subject=Sponsorship%20Enquiry%20-%20EoES%202027" class="btn btn--primary btn--lg">
        Get in touch
        <svg class="arrow" viewBox="0 0 24 24"><path d="M5 12h14M13 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </a>
      <a href="/sponsors/2026" class="btn btn--ghost btn--lg">View 2026 sponsors</a>
    </div>
  </div>
</section>

</BaseLayout>

<style>
  .clean-list {
    list-style: none;
    padding: 0;
    margin: 0;
    font-size: 14px;
    line-height: 1.8;
    text-align: left;
  }

  .clean-list li + li {
    margin-top: 8px;
  }

  .addon-card {
    border-color: rgba(124,58,237,0.3);
    background: linear-gradient(180deg, rgba(124,58,237,0.08) 0%, transparent 100%);
  }

  .addon-price {
    font-family: var(--font-display);
    font-size: 22px;
    letter-spacing: -0.04em;
    color: var(--ink-0);
  }

  .tier-detail {
    padding: 0;
    overflow: hidden;
  }

  .tier-detail-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    flex-wrap: wrap;
    padding: 28px 32px;
    border-bottom: 1px solid var(--line-1);
  }

  .tier-detail > p {
    padding: 28px 32px;
  }

  .tier-detail-name {
    font-size: 11px;
    color: rgba(255,255,255,0.62);
    margin-bottom: 6px;
    letter-spacing: 0.04em;
  }

  .tier-detail-price {
    font-family: var(--font-display);
    font-size: 48px;
    line-height: 0.9;
    letter-spacing: -0.06em;
    color: var(--ink-0);
  }

  .tier-detail-meta {
    font-size: 11px;
    color: var(--ink-3);
    margin-top: 6px;
  }

  .tier-detail-badge {
    padding: 10px 16px;
    background: rgba(255,255,255,0.14);
    border-radius: 8px;
    border: 1px solid rgba(255,255,255,0.2);
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 700;
    color: rgba(255,255,255,0.9);
  }

  .tier-detail--platinum .tier-detail-head {
    background: linear-gradient(135deg, rgba(124,58,237,0.5) 0%, rgba(236,72,153,0.5) 100%);
  }

  .tier-detail--gold .tier-detail-head {
    background: rgba(251,191,36,0.85);
  }

  .tier-detail--gold .tier-detail-name,
  .tier-detail--gold .tier-detail-meta {
    color: rgba(0,0,0,0.55);
  }

  .tier-detail--gold .tier-detail-price {
    color: #1a0f00;
  }

  .tier-detail--silver .tier-detail-head {
    background: rgba(148,163,184,0.14);
  }

  .tier-detail--community .tier-detail-head {
    background: rgba(124,58,237,0.52);
  }

  .tier-detail--friend .tier-detail-head {
    background: rgba(124,58,237,0.28);
  }

  /* Recruitment Partner sits outside the ladder, so it gets its own pink identity. */
  .tier-detail--recruitment .tier-detail-head {
    background: linear-gradient(135deg, rgba(236,72,153,0.55) 0%, rgba(124,58,237,0.40) 100%);
  }

  .recruitment-body {
    padding: 28px 32px;
  }

  .recruitment-list {
    font-size: 14px;
  }

  .recruitment-list li {
    position: relative;
    padding-left: 22px;
    color: var(--ink-2);
  }

  .recruitment-list li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0.65em;
    width: 8px;
    height: 2px;
    background: var(--pink);
  }
</style>
