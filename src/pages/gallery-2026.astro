---
import { existsSync, readdirSync, statSync } from 'node:fs';
import { join } from 'node:path';
import BaseLayout from '../layouts/BaseLayout.astro';

const galleryDir = join(process.cwd(), 'public', 'images', 'gallery', '2026');
const imageExtensions = new Set(['.avif', '.webp', '.jpg', '.jpeg', '.png']);
const hiddenNamePattern = /(?:^|[-_\s.])hide(?:[-_\s.]|$)/i;

const toTitle = (fileName: string) => {
  const withoutExtension = fileName.replace(/\.[^.]+$/, '');
  const cleaned = withoutExtension
    .replace(/^\d+[\s._-]*/, '')
    .replace(/[-_]+/g, ' ')
    .replace(/\s+/g, ' ')
    .trim();

  return cleaned || 'EoES 2026 gallery photo';
};

const photos = existsSync(galleryDir)
  ? readdirSync(galleryDir, { withFileTypes: true })
      .filter((entry) => entry.isFile())
      .map((entry) => {
        const fileName = entry.name;
        const filePath = join(galleryDir, fileName);
        const leadingNumber = fileName.match(/^(\d+)/);
        return {
          fileName,
          rank: leadingNumber ? Number(leadingNumber[1]) : Number.MAX_SAFE_INTEGER,
          size: statSync(filePath).size,
        };
      })
      .filter(({ fileName }) => imageExtensions.has(fileName.slice(fileName.lastIndexOf('.')).toLowerCase()))
      .filter(({ fileName }) => !hiddenNamePattern.test(fileName))
      .sort((a, b) => {
        if (a.rank !== b.rank) return a.rank - b.rank;
        // both are numbered files — already distinct
        // both are unnumbered — sort by file size ascending
        return a.size - b.size;
      })
      .map(({ fileName }, index) => {
        // Grid shows a pre-generated 640px thumb; the lightbox loads the original.
        const thumbName = fileName.replace(/\.[^.]+$/, '.jpg');
        const hasThumb = existsSync(join(galleryDir, 'thumbs', thumbName));
        return {
          src: encodeURI(`/images/gallery/2026/${fileName}`),
          thumb: hasThumb
            ? encodeURI(`/images/gallery/2026/thumbs/${thumbName}`)
            : encodeURI(`/images/gallery/2026/${fileName}`),
          alt: `${toTitle(fileName)} - EoES 2026 photo ${index + 1}`,
        };
      })
  : [];
---

<BaseLayout
  title="2026 Gallery"
  description="Photos from the East of England Summit 2026 in Norwich."
>

<section class="page-hero">
  <div class="bg-year" aria-hidden="true">26</div>
  <span class="spark" style="top: 22%; left: 7%;"></span>
  <span class="spark sm" style="top: 65%; right: 12%;"></span>
  <div class="container">
    <div class="hero-eyebrow"><div class="chip"><span class="dot" style="background: var(--ink-3); box-shadow: 0 0 0 4px rgba(255,255,255,0.08);"></span><span>2026 Archive · Gallery</span></div></div>
    <h1 class="display-1 hero-title" style="max-width: 16ch;">EoES 2026<br><span class="display-italic">in pictures.</span></h1>
    <p class="hero-sub">Photos from the East of England Summit 2026. Photography by Martin Eley-Kemp.</p>
    <div style="margin-top: 28px;">
      <a
        href="https://www.instagram.com/lacunaaspect/"
        target="_blank"
        rel="noopener noreferrer"
        style="display: inline-flex; align-items: center; gap: 12px; text-decoration: none; padding: 12px 20px; background: rgba(255,255,255,0.06); border: 1px solid var(--line-1); border-radius: 12px; transition: background 0.2s;"
        aria-label="Martin Eley-Kemp – Lacuna Aspect on Instagram"
      >
        <img
          src="/images/lacuna-logo.jpg"
          alt="Lacuna Aspect logo"
          style="height: 36px; width: auto; object-fit: contain; opacity: 0.9;"
        />
        <span class="mono" style="font-size: 13px; color: var(--ink-2);">Martin Eley-Kemp &nbsp;·&nbsp; @lacunaaspect</span>
      </a>
    </div>
  </div>
</section>

<section class="section">
  <div class="container">
    <div style="display: flex; align-items: flex-end; justify-content: space-between; gap: 16px; flex-wrap: wrap; margin-bottom: 32px;">
      <div>
        <div class="eyebrow" style="margin-bottom: 10px;">— Event Photos —</div>
        <h2 class="display-3" style="margin: 0;">On the day.</h2>
      </div>
      {photos.length > 0 && (
        <p class="mono" style="color: var(--ink-3); font-size: 13px;">{photos.length} photos</p>
      )}
    </div>

    {photos.length > 0 ? (
      <div class="gallery-grid" aria-label="EoES 2026 photo gallery">
        {photos.map((photo, index) => (
          <button
            type="button"
            class="gallery-item"
            data-gallery-src={photo.src}
            data-gallery-alt={photo.alt}
            aria-label={`Open ${photo.alt}`}
          >
            <img
              src={photo.thumb}
              alt={photo.alt}
              width="640"
              height="480"
              loading={index < 8 ? 'eager' : 'lazy'}
              decoding="async"
            />
          </button>
        ))}
      </div>
    ) : (
      <div class="frame-panel center" style="max-width: 560px; margin: 0 auto;">
        <div class="eyebrow eyebrow--center" style="margin-bottom: 14px;">— Coming soon —</div>
        <h3 class="display-3" style="margin-bottom: 14px;">Photos coming<br><span class="display-italic">soon.</span></h3>
        <p class="muted" style="max-width: 44ch; margin: 0 auto;">The 2026 gallery will appear here once the web-optimised event photos are ready.</p>
      </div>
    )}
  </div>
</section>

<dialog id="gallery-dialog" class="gallery-dialog" aria-label="Expanded gallery photo">
  <button type="button" class="gallery-close" data-gallery-close aria-label="Close photo">
    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18 18 6M6 6l12 12" />
    </svg>
  </button>
  <img id="gallery-dialog-image" src="" alt="" />
</dialog>

</BaseLayout>

<script>
  const dialog = document.getElementById('gallery-dialog') as HTMLDialogElement | null;
  const dialogImage = document.getElementById('gallery-dialog-image') as HTMLImageElement | null;

  document.addEventListener('click', (event) => {
    const target = event.target as HTMLElement | null;
    const item = target?.closest('[data-gallery-src]') as HTMLElement | null;
    const closeButton = target?.closest('[data-gallery-close]');

    if (closeButton) {
      dialog?.close();
      return;
    }

    if (!item || !dialog || !dialogImage) {
      return;
    }

    dialogImage.src = item.dataset.gallerySrc || '';
    dialogImage.alt = item.dataset.galleryAlt || 'Expanded EoES 2026 gallery photo';
    dialog.showModal();
  });

  dialog?.addEventListener('click', (event) => {
    if (event.target === dialog) {
      dialog.close();
    }
  });

  dialog?.addEventListener('close', () => {
    if (dialogImage) {
      dialogImage.removeAttribute('src');
      dialogImage.alt = '';
    }
  });
</script>

<style>
  .gallery-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }

  @media (min-width: 640px) {
    .gallery-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (min-width: 1024px) {
    .gallery-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  @media (min-width: 1280px) {
    .gallery-grid {
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }
  }

  .gallery-item {
    display: block;
    width: 100%;
    aspect-ratio: 4 / 3;
    padding: 0;
    border: 0;
    border-radius: 10px;
    overflow: hidden;
    background: rgba(255,255,255,0.04);
    box-shadow: 0 4px 16px rgba(0,0,0,0.4);
    cursor: zoom-in;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .gallery-item:hover {
    transform: translateY(-3px);
    box-shadow: 0 12px 32px rgba(0,0,0,0.5);
  }

  .gallery-item img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .gallery-dialog {
    width: min(94vw, 1200px);
    max-width: 1200px;
    max-height: 92vh;
    padding: 0;
    border: 0;
    border-radius: 10px;
    background: transparent;
    overflow: visible;
  }

  .gallery-dialog::backdrop {
    background: rgba(5, 0, 15, 0.92);
  }

  .gallery-dialog img {
    display: block;
    width: 100%;
    max-height: 92vh;
    object-fit: contain;
    border-radius: 10px;
    background: #0B0118;
  }

  .gallery-close {
    position: absolute;
    top: -0.75rem;
    right: -0.75rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.75rem;
    height: 2.75rem;
    border: 0;
    border-radius: 999px;
    color: #323130;
    background: #fff;
    box-shadow: 0 12px 30px -12px rgba(0, 0, 0, 0.6);
    cursor: pointer;
  }
</style>
