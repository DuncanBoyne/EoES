---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Home"
  description="EoES 2027 — East of England Summit returns 30 April – 1 May 2027. Two days of hands-on workshops and conference sessions in Norwich, Norfolk."
>

<section class="page-hero">
  <div class="bg-year" aria-hidden="true">27</div>
  <span class="spark" style="top: 18%; left: 6%;"></span>
  <span class="spark sm" style="top: 32%; right: 8%;"></span>
  <span class="spark" style="top: 70%; left: 12%;"></span>
  <span class="spark sm" style="top: 84%; right: 18%;"></span>
  <span class="spark sm" style="top: 12%; left: 38%;"></span>

  <div class="container">
    <div style="display: grid; grid-template-columns: 1.4fr 1fr; gap: clamp(40px, 6vw, 96px); align-items: center;" class="hero-grid">
      <div>
        <div class="chip chip--yellow" style="margin-bottom: 28px;">
          <span class="dot"></span>
          <span>Save the Date · Vol 02 · 2027</span>
        </div>

        <h1 class="display-1" style="margin-bottom: 28px;">
          <span class="gradient-white-lavender">East of England</span><br>
          <span class="display-italic">Summit.</span>
        </h1>

        <p class="lead" style="max-width: 56ch; margin-bottom: 36px;">
          The Microsoft Power Platform community of the East returns to Norwich for <b>two days</b> of hands-on workshops and conference sessions. <b>Build, learn, connect.</b>
        </p>

        <div class="row" style="gap: 12px;">
          <a href="/sponsorship" class="btn btn--primary btn--lg">
            Sponsor EoES 2027
            <svg class="arrow" viewBox="0 0 24 24"><path d="M5 12h14M13 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
          <a href="https://www.linkedin.com/company/eoes/" target="_blank" rel="noopener noreferrer" class="btn btn--ghost btn--lg">
            Follow updates<span class="sr-only"> (opens in new tab)</span>
          </a>
        </div>
      </div>

      <div style="position: relative;">
        <div class="orbit" style="width: 480px; height: 480px; top: -60px; right: -120px; opacity: 0.5;"></div>
        <div class="orbit" style="width: 360px; height: 360px; top: 0; right: -60px; border-style: solid; border-color: rgba(255,255,255,0.06);"></div>

        <div class="halo" style="width: 200px; height: 200px; margin: 0 auto 36px;">
          <div class="halo-inner"><img src="/images/logo-hero.png" alt="EoES logo"></div>
        </div>

        <div class="ticket">
          <div class="tk">
            <div class="tk-label">Day 01 · Workshops</div>
            <div class="tk-day-row">
              <div class="tk-day">30</div>
              <div>
                <div class="tk-month">April</div>
                <div class="tk-weekday">Friday</div>
              </div>
            </div>
            <div class="tk-venue">
              <b>Norwich</b>
              <span class="pending">Venue announced soon</span>
            </div>
          </div>
          <div class="tk tk-right">
            <div class="tk-label">Day 02 · Conference</div>
            <div class="tk-day-row">
              <div class="tk-day">01</div>
              <div>
                <div class="tk-month">May</div>
                <div class="tk-weekday">Saturday</div>
              </div>
            </div>
            <div class="tk-venue">
              <b>Norwich</b>
              <span class="pending">Venue announced soon</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="issue-mark"><b>Vol — 02</b> &nbsp;·&nbsp; Norwich · 2027</div>
</section>

<section class="section">
  <div class="container">
    <div class="section-head section-head--center">
      <div class="eyebrow eyebrow--center">— What EoES Offers —</div>
      <h2 class="display-2">Two days of Power Platform,<br><span class="display-italic">built for the community.</span></h2>
      <p class="sub">A community-led conference bringing Power Platform professionals together for hands-on learning, expert sessions, and real connections.</p>
    </div>

    <div class="grid-3">
      <article class="card">
        <span class="card-num">01</span>
        <div class="card-icon yellow">
          <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 6.25v13M12 6.25C10.83 5.48 9.25 5 7.5 5S4.17 5.48 3 6.25v13C4.17 18.48 5.75 18 7.5 18s3.33.48 4.5 1.25M12 6.25C13.17 5.48 14.75 5 16.5 5c1.75 0 3.33.48 4.5 1.25v13c-1.17-.77-2.75-1.25-4.5-1.25-1.75 0-3.33.48-4.5 1.25" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </div>
        <h3 class="card-title">Hands-on Workshops</h3>
        <p class="card-body">A dedicated workshop day on Friday — small-group sessions where you actually build, guided by expert instructors from the Power Platform community.</p>
      </article>

      <article class="card">
        <span class="card-num">02</span>
        <div class="card-icon pink">
          <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 11a7 7 0 01-14 0M12 18v4m-4 0h8M9 5a3 3 0 016 0v6a3 3 0 01-6 0V5z" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </div>
        <h3 class="card-title">Expert Sessions</h3>
        <p class="card-body">Parallel tracks of conference talks from community experts, Microsoft MVPs, and practitioners sharing real-world Power Platform experience.</p>
      </article>

      <article class="card">
        <span class="card-num">03</span>
        <div class="card-icon cyan">
          <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 20h5v-2a3 3 0 00-5.36-1.86M17 20H7m10 0v-2c0-.66-.13-1.28-.36-1.86M7 20H2v-2a3 3 0 015.36-1.86M7 20v-2c0-.66.13-1.28.36-1.86m0 0a5 5 0 019.28 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </div>
        <h3 class="card-title">Networking</h3>
        <p class="card-body">Connect with Power Platform professionals from across the region. Build relationships that go beyond the conference floor.</p>
      </article>

      <article class="card">
        <span class="card-num">04</span>
        <div class="card-icon purple">
          <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </div>
        <h3 class="card-title">Multiple Tracks</h3>
        <p class="card-body">Sessions covering Power Apps, Power Automate, Power BI, Power Pages, Copilot Studio, Dataverse and the broader Microsoft cloud ecosystem.</p>
      </article>

      <article class="card">
        <span class="card-num">05</span>
        <div class="card-icon yellow">
          <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </div>
        <h3 class="card-title">Exhibition Area</h3>
        <p class="card-body">An expo hall with sponsors, partners and vendors showcasing the latest tooling, services and opportunities across the Power Platform ecosystem.</p>
      </article>

      <article class="card">
        <span class="card-num">06</span>
        <div class="card-icon pink">
          <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2"><path d="M4.32 6.32a4.5 4.5 0 000 6.36L12 20.36l7.68-7.68a4.5 4.5 0 00-6.36-6.36L12 7.64l-1.32-1.32a4.5 4.5 0 00-6.36 0z" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </div>
        <h3 class="card-title">Community-Led</h3>
        <p class="card-body">Organised entirely by volunteers from the Norfolk Power Platform User Group — built for the community, by the community, every single year.</p>
      </article>
    </div>
  </div>
</section>

<section class="section section--tight">
  <div class="container">
    <div class="frame-panel" style="display: grid; grid-template-columns: 1.2fr 1fr; gap: clamp(32px, 5vw, 72px); align-items: center;">
      <div>
        <div class="eyebrow" style="margin-bottom: 22px;">— Returning, bigger —</div>
        <h2 class="display-3" style="margin-bottom: 22px;">
          Same community.<br>
          <span class="gradient-yellow-pink">Broader scope.</span>
        </h2>
        <p class="lead muted">EoES 2027 builds on the foundation of 2026 with two full days of programming. Friday workshops in small-group, hands-on format. Saturday conference with parallel tracks, keynote, expo hall and lunch included.</p>
        <div class="row" style="margin-top: 28px; gap: 12px;">
          <a href="/why-attend" class="btn btn--pink">Why attend</a>
          <a href="/sponsorship" class="btn btn--ghost">Sponsor options</a>
        </div>
      </div>

      <div style="display: grid; gap: 16px;">
        <div style="display: grid; grid-template-columns: auto 1fr; gap: 18px; align-items: center; padding: 18px 22px; background: rgba(251,191,36,0.06); border: 1px solid rgba(251,191,36,0.25); border-radius: 14px;">
          <div class="mono" style="color: var(--yellow);">DAY 01</div>
          <div>
            <div style="font-family: var(--font-display); font-size: 24px; color: var(--ink-0); letter-spacing: -0.02em;">Friday 30 April</div>
            <div class="mono" style="color: var(--ink-3); margin-top: 4px;">Workshops · Ticketed · Limited places</div>
          </div>
        </div>
        <div style="display: grid; grid-template-columns: auto 1fr; gap: 18px; align-items: center; padding: 18px 22px; background: rgba(236,72,153,0.06); border: 1px solid rgba(236,72,153,0.25); border-radius: 14px;">
          <div class="mono" style="color: var(--pink);">DAY 02</div>
          <div>
            <div style="font-family: var(--font-display); font-size: 24px; color: var(--ink-0); letter-spacing: -0.02em;">Saturday 01 May</div>
            <div class="mono" style="color: var(--ink-3); margin-top: 4px;">Conference · Free to attend</div>
          </div>
        </div>
        <div style="display: grid; grid-template-columns: auto 1fr; gap: 18px; align-items: center; padding: 18px 22px; background: rgba(34,211,238,0.06); border: 1px solid rgba(34,211,238,0.25); border-radius: 14px;">
          <div class="mono" style="color: var(--cyan);">CITY</div>
          <div>
            <div style="font-family: var(--font-display); font-size: 24px; color: var(--ink-0); letter-spacing: -0.02em;">Norwich, Norfolk</div>
            <div class="mono" style="color: var(--ink-3); margin-top: 4px;">East of England · UK</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="section">
  <div class="container">
    <div class="section-head">
      <div class="eyebrow">— 2026 Archive —</div>
      <h2 class="display-3">A look back at <span class="display-italic">2026.</span></h2>
      <p class="sub">Thank you to everyone who attended, spoke, sponsored and volunteered. EoES 2026 in full — gallery, speakers, sponsors and the full session catalogue still online.</p>
    </div>

    <div class="grid-3">
      <a href="/gallery-2026" class="card" style="display: block; text-decoration: none;">
        <div class="mono" style="color: var(--yellow); margin-bottom: 14px;">PHOTOGRAPHY</div>
        <h3 class="card-title">Gallery 2026</h3>
        <p class="card-body">Event photography by Martin Eley-Kemp · Lacuna Aspect.</p>
        <div class="mono" style="margin-top: 22px; color: var(--ink-0);">View gallery &nbsp;→</div>
      </a>
      <a href="/speakers" class="card" style="display: block; text-decoration: none;">
        <div class="mono" style="color: var(--pink); margin-bottom: 14px;">CONTRIBUTORS</div>
        <h3 class="card-title">Speakers 2026</h3>
        <p class="card-body">All speakers from EoES 2026 including keynote Chris Huntingford.</p>
        <div class="mono" style="margin-top: 22px; color: var(--ink-0);">View speakers &nbsp;→</div>
      </a>
      <a href="/sessions" class="card" style="display: block; text-decoration: none;">
        <div class="mono" style="color: var(--cyan); margin-bottom: 14px;">PROGRAMME</div>
        <h3 class="card-title">Sessions 2026</h3>
        <p class="card-body">31 sessions across 4 tracks — filterable by topic, level and room.</p>
        <div class="mono" style="margin-top: 22px; color: var(--ink-0);">Browse catalogue &nbsp;→</div>
      </a>
    </div>
  </div>
</section>

<section class="section section--tight">
  <div class="container">
    <div class="section-head section-head--center">
      <div class="eyebrow eyebrow--center">— Thank you · 2026 Sponsors —</div>
      <h2 class="display-3">EoES 2026 was made possible<br>by these companies.</h2>
    </div>

    <div class="grid-4" style="margin-bottom: 28px;">
      <div class="sponsor-lockup gold">
        <div class="tier">Gold Sponsor 2026</div>
        <div class="logo-box artwork"><img src="/images/sponsors/GTP-Tech.png" alt="GTP Tech Recruitment"></div>
        <div class="body"><p class="name">GTP Tech Recruitment</p></div>
      </div>
      <div class="sponsor-lockup">
        <div class="tier">Community 2026</div>
        <div class="logo-box dark"><img src="/images/sponsors/Powercademy.png" alt="Powercademy"></div>
        <div class="body"><p class="name">Powercademy</p></div>
      </div>
      <div class="sponsor-lockup">
        <div class="tier">Community 2026</div>
        <div class="logo-box artwork"><img src="/images/sponsors/PowerPagesMastery.png" alt="Power Pages Mastery"></div>
        <div class="body"><p class="name">Power Pages Mastery</p></div>
      </div>
      <div class="sponsor-lockup">
        <div class="tier">Community 2026</div>
        <div class="logo-box artwork"><img src="/images/sponsors/ExtraLife.png" alt="Extra Life"></div>
        <div class="body"><p class="name">Extra Life</p></div>
      </div>
      <div class="sponsor-lockup">
        <div class="tier">Community 2026</div>
        <div class="logo-box artwork"><img src="/images/sponsors/Untethered365.png" alt="Untethered 365"></div>
        <div class="body"><p class="name">Untethered 365</p></div>
      </div>
      <div class="sponsor-lockup">
        <div class="tier">Community 2026</div>
        <div class="logo-box dark wide"><img src="/images/sponsors/ExpertsLiveUK.png" alt="Experts Live UK"></div>
        <div class="body"><p class="name">Experts Live UK</p></div>
      </div>
      <div class="sponsor-lockup">
        <div class="tier">Community 2026</div>
        <div class="logo-box"><img src="/images/sponsors/P3 on Light Background.png" alt="Proximo3"></div>
        <div class="body"><p class="name">Proximo3</p></div>
      </div>
      <a href="/sponsors/2026" class="sponsor-lockup" style="text-decoration: none; align-items: stretch;">
        <div class="tier" style="color: var(--yellow);">View All →</div>
        <div class="logo-box" style="background: rgba(255,255,255,0.02); border: 0;">
          <div class="mono" style="color: var(--ink-2);">All 2026 Sponsors</div>
        </div>
        <div class="body"><p class="name">Full archive of EoES 2026 sponsors and partners.</p></div>
      </a>
    </div>

    <div class="row" style="justify-content: center; gap: 12px;">
      <a href="/sponsorship" class="btn btn--primary btn--lg">Become a 2027 sponsor</a>
      <a href="/sponsors/2026" class="btn btn--ghost btn--lg">View 2026 sponsors</a>
    </div>
  </div>
</section>

<section class="cta-strip">
  <div class="container center">
    <div class="eyebrow eyebrow--center" style="margin-bottom: 22px;">— Stay Connected —</div>
    <h2 class="display-2" style="max-width: 22ch; margin: 0 auto 22px;">
      Be first to hear<br><span class="display-italic">EoES 2027 news.</span>
    </h2>
    <p class="lead muted" style="max-width: 56ch; margin: 0 auto 36px;">Speaker reveals, workshop schedule, venue confirmation, sponsor announcements — all dropping on LinkedIn first.</p>
    <div class="row" style="justify-content: center; gap: 12px;">
      <a href="https://www.linkedin.com/company/eoes/" target="_blank" rel="noopener noreferrer" class="btn btn--primary btn--lg">
        Follow on LinkedIn
        <svg class="arrow" viewBox="0 0 24 24"><path d="M5 12h14M13 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </a>
      <a href="/sponsorship" class="btn btn--ghost btn--lg">Sponsor 2027</a>
    </div>
  </div>
</section>

</BaseLayout>
