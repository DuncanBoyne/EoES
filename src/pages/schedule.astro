---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Schedule"
  description="Two-day schedule for EoES 2027 — workshops Friday 30 April, conference Saturday 1 May in Norwich."
>

<section class="page-hero">
  <div class="bg-year" aria-hidden="true">2D</div>
  <span class="spark" style="top: 22%; left: 7%;"></span>
  <span class="spark sm" style="top: 60%; right: 10%;"></span>
  <div class="container">
    <div class="hero-eyebrow"><div class="chip chip--purple"><span class="dot"></span><span>Two-day schedule · 2027</span></div></div>
    <h1 class="display-1 hero-title" style="max-width: 18ch;">Two days of<br>Power Platform<br><span class="display-italic">in Norwich.</span></h1>
    <p class="hero-sub">Friday 30 April 2027 — workshops. Saturday 1 May 2027 — conference. Both days at venues in central Norwich, walking distance from the railway station.</p>
  </div>
  <div class="issue-mark"><b>Vol — 02</b> &nbsp;·&nbsp; Schedule</div>
</section>

<section class="section">
  <div class="container">
    <div style="display: grid; grid-template-columns: 200px 1fr; gap: 36px; align-items: start; margin-bottom: 36px;" class="day-row">
      <div class="card" style="padding: 28px; text-align: center; background: linear-gradient(180deg, rgba(251,191,36,0.10) 0%, transparent 100%); border-color: rgba(251,191,36,0.3);">
        <div class="mono" style="color: var(--yellow); margin-bottom: 8px;">FRIDAY</div>
        <div style="font-family: var(--font-display); font-size: 80px; line-height: 0.86; color: var(--yellow); letter-spacing: -0.06em;">30</div>
        <div class="mono" style="color: var(--ink-2); margin-top: 8px;">APRIL · 2027</div>
      </div>
      <div>
        <div class="eyebrow" style="margin-bottom: 14px;">— Day 01 —</div>
        <h2 class="display-3" style="margin-bottom: 14px;">Workshop Day.</h2>
        <div class="row" style="gap: 18px; color: var(--ink-3); font-size: 15px;">
          <span class="mono" style="color: var(--ink-2);">09:00 — 16:30</span>
          <span class="mono" style="color: var(--ink-2);">Norwich (venue TBA)</span>
        </div>
        <p class="muted" style="margin-top: 18px; max-width: 60ch;">Bring your laptop and get ready to build. Workshop details and speakers will be confirmed closer to the event — keep an eye on LinkedIn.</p>
      </div>
    </div>

    <div class="card" style="padding: 0; background: rgba(255,255,255,0.02);">
      <div style="padding: 24px 36px; border-bottom: 1px solid var(--line-1);">
        <p class="muted" style="margin: 0; font-size: 14px;">Indicative timings — final agenda confirmed alongside workshop announcements.</p>
      </div>
      <div class="schedule-list" style="padding: 0 36px;">
        <div class="schedule-row">
          <div class="when">09:00</div>
          <div>
            <span class="kind" style="color: var(--ink-3);">REGISTRATION</span>
            <h3 class="title">Registration &amp; welcome</h3>
            <p class="desc">Arrive, grab a coffee, and get settled. Quick welcome from the team.</p>
          </div>
          <div class="dur">15 min</div>
        </div>
        <div class="schedule-row">
          <div class="when">09:15</div>
          <div>
            <span class="kind" style="color: var(--yellow);">WORKSHOP</span>
            <h3 class="title">Morning workshop</h3>
            <p class="desc">Speaker and topic to be announced.</p>
          </div>
          <div class="dur">3h 15m</div>
        </div>
        <div class="schedule-row" style="background: rgba(251,191,36,0.04);">
          <div class="when" style="color: var(--pink);">12:30</div>
          <div>
            <span class="kind" style="color: var(--pink);">LUNCH</span>
            <h3 class="title">Lunch &amp; networking</h3>
            <p class="desc">Lunch provided. A great opportunity to connect with fellow attendees.</p>
          </div>
          <div class="dur">1h</div>
        </div>
        <div class="schedule-row">
          <div class="when">13:30</div>
          <div>
            <span class="kind" style="color: var(--yellow);">WORKSHOP</span>
            <h3 class="title">Afternoon workshop</h3>
            <p class="desc">Speaker and topic to be announced.</p>
          </div>
          <div class="dur">2h 30m</div>
        </div>
        <div class="schedule-row">
          <div class="when">16:00</div>
          <div>
            <span class="kind" style="color: var(--ink-3);">CLOSE</span>
            <h3 class="title">Close</h3>
            <p class="desc">Wrap up and close. Venue closes at 16:30.</p>
          </div>
          <div class="dur">—</div>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="section">
  <div class="container">
    <div style="display: grid; grid-template-columns: 200px 1fr; gap: 36px; align-items: start; margin-bottom: 36px;" class="day-row">
      <div class="card" style="padding: 28px; text-align: center; background: linear-gradient(180deg, rgba(236,72,153,0.10) 0%, transparent 100%); border-color: rgba(236,72,153,0.3);">
        <div class="mono" style="color: var(--pink); margin-bottom: 8px;">SATURDAY</div>
        <div style="font-family: var(--font-display); font-size: 80px; line-height: 0.86; letter-spacing: -0.06em;" class="gradient-pink-purple">01</div>
        <div class="mono" style="color: var(--ink-2); margin-top: 8px;">MAY · 2027</div>
      </div>
      <div>
        <div class="eyebrow" style="color: var(--pink); margin-bottom: 14px;">— Day 02 —</div>
        <h2 class="display-3" style="margin-bottom: 14px;">Conference Day.</h2>
        <div class="row" style="gap: 18px; color: var(--ink-3); font-size: 15px;">
          <span class="mono" style="color: var(--ink-2);">08:00 — 17:30</span>
          <span class="mono" style="color: var(--ink-2);">Norwich (venue TBA)</span>
        </div>
        <p class="muted" style="margin-top: 18px; max-width: 60ch;">Full conference programme with keynote, parallel tracks, sponsor exhibition, lunch and networking. Free to attend.</p>
      </div>
    </div>

    <!-- 2026 Archive session grid -->
    <div class="section-head" style="margin-bottom: 32px;">
      <div class="eyebrow">— 2026 Archive —</div>
      <h3 class="display-3">Browse the 2026 sessions.</h3>
      <p class="sub">The 2027 programme will be announced via LinkedIn. In the meantime, explore the full 2026 session grid below.</p>
    </div>

    <link rel="stylesheet" href="https://sessionize.com/api/v2/9q20ek5l/embedstyle" />
    <div class="sessionize-embed">
      <script is:inline src="https://sessionize.com/api/v2/9q20ek5l/view/GridSmart"></script>
    </div>
  </div>
</section>

<!-- Modal container required by Sessionize -->
<div id="sz-modal-container" class="is-hidden"></div>

<section class="cta-strip">
  <div class="container center">
    <div class="eyebrow eyebrow--center" style="margin-bottom: 22px;">— Stay up to date —</div>
    <h2 class="display-2" style="max-width: 20ch; margin: 0 auto 22px;">Programme drops<br><span class="display-italic">on LinkedIn first.</span></h2>
    <div class="row" style="justify-content: center; gap: 12px;">
      <a href="https://www.linkedin.com/company/eoes/" target="_blank" rel="noopener noreferrer" class="btn btn--primary btn--lg">Follow on LinkedIn</a>
      <a href="/sessions" class="btn btn--ghost btn--lg">View 2026 sessions</a>
    </div>
  </div>
</section>

<style>
  @media (max-width: 700px) { .day-row { grid-template-columns: 1fr !important; } }
</style>

</BaseLayout>
