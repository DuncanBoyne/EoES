---
import BaseLayout from '../layouts/BaseLayout.astro';

// Fetch room assignments from GridSmart at build time
const gridRes = await fetch('https://sessionize.com/api/v2/9q20ek5l/view/GridSmart?under=True', {
  headers: { 'User-Agent': 'Mozilla/5.0' }
});
const gridHtml = await gridRes.text();

// Map: sessionId -> trackId
const roomMap: Record<string, string> = {};
for (const m of gridHtml.matchAll(/data-sessionid="(\d+)"[^>]*grid-column[^"]*track-(\d+)/g)) {
  roomMap[m[1]] = m[2];
}

const rooms = [
  { id: '74435', label: 'The Auditorium' },
  { id: '74437', label: 'The Blue Space' },
  { id: '78123', label: 'The Orange Space' },
  { id: '74436', label: 'The Yellow Space' },
];

const roomMapJson = JSON.stringify(roomMap);
---

<BaseLayout
  title="2026 Sessions"
  description="Browse all Power Platform sessions from EoES 2026 — talks covering Power Apps, Power Automate, Power BI, Copilot Studio, and more."
>

<section class="page-hero">
  <div class="bg-year" aria-hidden="true">26</div>
  <span class="spark" style="top: 22%; left: 7%;"></span>
  <span class="spark sm" style="top: 60%; right: 10%;"></span>
  <div class="container">
    <div class="hero-eyebrow"><div class="chip"><span class="dot" style="background: var(--ink-3); box-shadow: 0 0 0 4px rgba(255,255,255,0.08);"></span><span>2026 Archive · Sessions</span></div></div>
    <h1 class="display-1 hero-title" style="max-width: 18ch;">31 sessions.<br><span class="display-italic">4 tracks.</span></h1>
    <p class="hero-sub">Browse every session from EoES 2026. Filter by track, level, or room to find exactly what you're looking for.</p>
  </div>
</section>

<!-- Sticky filter bar -->
<div class="sessions-filter-bar">
  <div class="container">

    <!-- Row 1: Track + Level -->
    <div class="filter-row">
      <div class="filter-group" role="group" aria-label="Filter sessions by track">
        <span class="filter-label">Track</span>
        <button class="filter-btn filter-track active" data-track="all" aria-pressed="true">All</button>
        <button class="filter-btn filter-track" data-track="sz-tag_113750-409150" aria-pressed="false">Technical</button>
        <button class="filter-btn filter-track" data-track="sz-tag_113750-409151" aria-pressed="false">Business Adoption</button>
        <button class="filter-btn filter-track" data-track="sz-tag_113750-409148" aria-pressed="false">Non-Technical</button>
        <button class="filter-btn filter-track" data-track="sz-tag_113750-409149" aria-pressed="false">New Speaker</button>
      </div>
      <div class="filter-group" role="group" aria-label="Filter sessions by level">
        <span class="filter-label">Level</span>
        <button class="filter-btn filter-level active" data-level="all" aria-pressed="true">All</button>
        <button class="filter-btn filter-level" data-level="sz-tag_113748-409142" aria-pressed="false">100</button>
        <button class="filter-btn filter-level" data-level="sz-tag_113748-409143" aria-pressed="false">200</button>
        <button class="filter-btn filter-level" data-level="sz-tag_113748-409144" aria-pressed="false">300</button>
        <button class="filter-btn filter-level" data-level="sz-tag_113748-409145" aria-pressed="false">400</button>
      </div>
    </div>

    <!-- Row 2: Room filter -->
    <div class="filter-group" role="group" aria-label="Filter sessions by room">
      <span class="filter-label">Room</span>
      <button class="filter-btn filter-room active" data-room="all" aria-pressed="true">All Rooms</button>
      {rooms.map(r => (
        <button class="filter-btn filter-room" data-room={r.id} aria-pressed="false">{r.label}</button>
      ))}
    </div>

    <!-- Session count -->
    <p class="session-count" id="session-count" aria-live="polite">Loading sessions…</p>
  </div>
</div>

<!-- Sessionize Sessions embed -->
<section class="section" style="padding-top: 48px;">
  <div class="container">
    <link rel="stylesheet" href="https://sessionize.com/api/v2/9q20ek5l/embedstyle" />
    <div class="sessionize-embed" id="sessions-embed-wrapper">
      <script is:inline src="https://sessionize.com/api/v2/9q20ek5l/view/Sessions"></script>
    </div>
  </div>
</section>

<!-- Modal container required by Sessionize -->
<div id="sz-modal-container" class="is-hidden"></div>

<section class="cta-strip">
  <div class="container center">
    <div class="eyebrow eyebrow--center" style="margin-bottom: 22px;">— EoES Returns —</div>
    <h2 class="display-2" style="max-width: 22ch; margin: 0 auto 22px;">More sessions<br><span class="display-italic">in 2027.</span></h2>
    <p class="lead muted" style="max-width: 52ch; margin: 0 auto 32px;">These are the sessions from EoES 2026. Follow us on LinkedIn for updates on EoES 2027.</p>
    <div class="row" style="justify-content: center; gap: 12px;">
      <a href="https://www.linkedin.com/company/eoes/" target="_blank" rel="noopener noreferrer" class="btn btn--primary btn--lg">Follow on LinkedIn</a>
      <a href="/schedule" class="btn btn--ghost btn--lg">2027 Schedule</a>
    </div>
  </div>
</section>

</BaseLayout>

<style is:global>
  .sessions-filter-bar {
    position: sticky;
    top: 64px;
    z-index: 40;
    background: rgba(11, 1, 24, 0.96);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(255,255,255,0.08);
    box-shadow: 0 4px 20px rgba(0,0,0,0.4);
    padding: 16px 0;
  }
  .sessions-filter-bar .container { display: flex; flex-direction: column; gap: 10px; }
  .filter-row { display: flex; flex-wrap: wrap; gap: 12px; align-items: center; justify-content: space-between; }
  .filter-group { display: flex; flex-wrap: wrap; gap: 6px; align-items: center; }
  .filter-label {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink-3);
    margin-right: 4px;
    white-space: nowrap;
  }
  .session-count {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--ink-3);
    margin: 0;
  }

  .filter-btn {
    display: inline-flex;
    align-items: center;
    padding: 5px 14px;
    border-radius: 9999px;
    font-size: 13px;
    font-weight: 500;
    background: rgba(255,255,255,0.06);
    color: var(--ink-2);
    border: 1px solid rgba(255,255,255,0.1);
    cursor: pointer;
    transition: background 0.15s, color 0.15s, border-color 0.15s;
    font-family: var(--font-body);
  }
  .filter-btn:hover:not(.active) {
    background: rgba(255,255,255,0.1);
    color: var(--ink-1);
  }
  .filter-btn:focus-visible {
    outline: 2px solid var(--purple);
    outline-offset: 2px;
  }
  .filter-btn.active {
    background: var(--purple);
    color: #fff;
    border-color: var(--purple);
  }

  /* ── Sessionize session card overrides (dark theme) ── */
  .sz-session__title { color: var(--ink-0); }
  .sz-session a { color: var(--purple); }

  .sz-sessions--list {
    list-style: none !important;
    padding: 0 !important;
    margin: 0 !important;
    display: grid !important;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)) !important;
    gap: 1.25rem !important;
    align-items: stretch !important;
  }
  .sz-session {
    background: rgba(255,255,255,0.04) !important;
    border-radius: 1rem !important;
    padding: 1.25rem 1.5rem !important;
    box-shadow: 0 1px 3px rgba(0,0,0,.3), 0 4px 16px rgba(0,0,0,.2) !important;
    transition: box-shadow .2s, transform .2s !important;
    border: 1px solid rgba(255,255,255,0.08) !important;
    display: flex !important;
    flex-direction: column !important;
    height: 100% !important;
    box-sizing: border-box !important;
    margin: 0 !important;
  }
  .sz-session:hover {
    box-shadow: 0 4px 24px rgba(124,58,237,0.2) !important;
    transform: translateY(-2px) !important;
    border-color: rgba(124,58,237,0.3) !important;
  }
  .sz-session__title { font-size: 1rem; font-weight: 700; line-height: 1.35; margin: 0.5rem 0 0.75rem; color: var(--ink-0); }
  .sz-session__speakers { list-style: none; padding: 0; margin: 0 0 0.75rem; display: flex; flex-wrap: wrap; gap: 0.25rem; }
  .sz-session__speakers li:not(:last-child)::after { content: ',\00a0'; color: var(--ink-3); }
  .sz-session__speakers a { font-size: 0.875rem; font-weight: 600; color: var(--purple); text-decoration: none; }
  .sz-session__speakers a:hover { text-decoration: underline; }
  .sz-session__description { display: none; }
  .sz-tags { list-style: none; padding: 0; margin: 0.75rem 0 0; display: flex; flex-wrap: wrap; gap: 0.4rem; }
  .sz-tag { font-size: 0.7rem; font-weight: 600; padding: 0.2rem 0.6rem; border-radius: 99px; }

  /* Track tag colours */
  .sz-tag_113750-409150 { background: rgba(124,58,237,0.2); color: #c4b5fd; }
  .sz-tag_113750-409151 { background: rgba(251,191,36,0.15); color: #fbbf24; }
  .sz-tag_113750-409148 { background: rgba(236,72,153,0.15); color: #f9a8d4; }
  .sz-tag_113750-409149 { background: rgba(34,211,238,0.15); color: #67e8f9; }

  /* Level chips */
  .sz-tag_113748-409142 { background: rgba(255,255,255,0.08); color: var(--ink-2); }
  .sz-tag_113748-409143 { background: rgba(59,130,246,0.15); color: #93c5fd; }
  .sz-tag_113748-409144 { background: rgba(251,191,36,0.15); color: #fbbf24; }
  .sz-tag_113748-409145 { background: rgba(239,68,68,0.15); color: #fca5a5; }

  /* Duration chip */
  .sz-tag_113832-409384,
  .sz-tag_113832-409385,
  .sz-tag_113832-409386 { background: rgba(255,255,255,0.06); color: var(--ink-3); }

  .sz-spinner { background-color: var(--purple) !important; }
  .sz-session--filtered { display: none !important; }

  /* Clickable card cursor */
  .sz-session { cursor: pointer; }
  .sz-session__view-hint {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    margin-top: 0.5rem;
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--purple);
  }

  /* ── Modal overlay ── */
  #sz-modal-container {
    position: fixed;
    inset: 0;
    z-index: 9999;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1rem;
  }
  #sz-modal-container.is-hidden { display: none !important; }

  .sz-modal-overlay {
    position: fixed;
    inset: 0;
    background: rgba(5, 0, 15, 0.8);
    backdrop-filter: blur(4px);
    cursor: pointer;
  }

  .sz-modal-container-inner {
    position: relative;
    z-index: 1;
    width: 100%;
    max-width: 640px;
    max-height: 90vh;
    overflow-y: auto;
    border-radius: 1.25rem;
    background: #fff;
    box-shadow: 0 25px 60px rgba(0, 0, 0, 0.6), 0 8px 20px rgba(0,0,0,0.3);
    scrollbar-width: thin;
  }

  .sz-modal {
    position: relative;
    padding: 2rem;
  }

  /* ── Close button ── */
  .sz-modal__close {
    position: absolute;
    top: 1rem;
    right: 1rem;
    width: 2rem;
    height: 2rem;
    border-radius: 9999px;
    background: #f1f5f9;
    border: none;
    cursor: pointer;
    font-size: 0.875rem;
    color: #64748b;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.15s, color 0.15s;
    line-height: 1;
  }
  .sz-modal__close:hover { background: #fee2e2; color: #991b1b; }

  /* ── Session modal ── */
  .sz-modal-session .sz-session {
    background: transparent;
    border: none;
    box-shadow: none;
    padding: 0;
    cursor: default;
    border-radius: 0;
    transform: none !important;
  }
  .sz-modal-session .sz-session:hover { box-shadow: none; transform: none; }

  /* Speakers row at top */
  .sz-modal-session .sz-session__speakers {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin: 0 0 1rem;
  }
  .sz-modal-session .sz-session__speakers li { display: flex; }
  .sz-modal-session .sz-session__speakers li::after { display: none; }
  .sz-modal-session .sz-session__speakers a {
    font-size: 0.8rem;
    font-weight: 700;
    color: #5B21B6;
    background: #ede9fe;
    padding: 0.2rem 0.65rem;
    border-radius: 9999px;
    text-decoration: none;
  }
  .sz-modal-session .sz-session__speakers a:hover { background: #ddd6fe; }

  /* Title */
  .sz-modal-session .sz-session__title {
    font-size: 1.35rem;
    font-weight: 800;
    line-height: 1.25;
    color: #1e1b4b;
    margin: 0 0 1.25rem;
  }

  /* Meta row: room + time */
  .sz-modal-session .sz-session__room,
  .sz-modal-session .sz-session__time {
    display: inline-flex;
    align-items: center;
    font-size: 0.8rem;
    font-weight: 600;
    background: #f8fafc;
    border: 1px solid #e2e8f0;
    border-radius: 9999px;
    padding: 0.25rem 0.75rem;
    margin: 0 0.4rem 0.75rem 0;
    color: #475569;
  }

  /* Description */
  .sz-modal-session .sz-session__description {
    display: block;
    font-size: 0.9rem;
    line-height: 1.7;
    color: #374151;
    margin: 1rem 0;
    white-space: pre-line;
  }

  /* Tags */
  .sz-modal-session .sz-session__tags {
    list-style: none;
    padding: 0;
    margin: 1.25rem 0 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    padding-top: 1rem;
    border-top: 1px solid #f1f5f9;
  }

  /* ── Speaker modal ── */
  .sz-modal-speaker .sz-speaker--full {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .sz-modal-speaker .sz-speaker__photo {
    width: 100px;
    height: 100px;
    border-radius: 9999px;
    overflow: hidden;
    margin-bottom: 1rem;
    border: 3px solid #ede9fe;
    flex-shrink: 0;
  }
  .sz-modal-speaker .sz-speaker__photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .sz-modal-speaker .sz-speaker__name {
    font-size: 1.25rem;
    font-weight: 800;
    color: #1e1b4b;
    margin: 0 0 0.35rem;
  }

  .sz-modal-speaker .sz-speaker__tagline {
    font-size: 0.8rem;
    color: #64748b;
    font-weight: 500;
    margin: 0 0 1rem;
    max-width: 480px;
    line-height: 1.4;
  }

  .sz-modal-speaker .sz-speaker__links {
    list-style: none;
    padding: 0;
    margin: 0 0 1.25rem;
    display: flex;
    gap: 0.5rem;
    justify-content: center;
  }
  .sz-modal-speaker .sz-speaker__link {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.8rem;
    font-weight: 600;
    color: #5B21B6;
    background: #ede9fe;
    padding: 0.3rem 0.75rem;
    border-radius: 9999px;
    text-decoration: none;
  }
  .sz-modal-speaker .sz-speaker__link:hover { background: #ddd6fe; }
  .sz-modal-speaker .sz-speaker__link-icon { width: 1rem; height: 1rem; }

  .sz-modal-speaker .sz-speaker__bio {
    font-size: 0.875rem;
    line-height: 1.7;
    color: #374151;
    text-align: left;
    padding-top: 1rem;
    border-top: 1px solid #f1f5f9;
    width: 100%;
    margin: 0 0 1rem;
  }

  .sz-modal-speaker .sz-speaker__sessions {
    list-style: none;
    padding: 0;
    margin: 0;
    width: 100%;
    border-top: 1px solid #f1f5f9;
    padding-top: 1rem;
  }
  .sz-modal-speaker .sz-speaker__sessions li { margin-bottom: 0.4rem; }
  .sz-modal-speaker .sz-speaker__sessions a {
    font-size: 0.85rem;
    font-weight: 600;
    color: #5B21B6;
    text-decoration: none;
  }
  .sz-modal-speaker .sz-speaker__sessions a:hover { text-decoration: underline; }
</style>

<script is:inline define:vars={{ roomMapJson }}>
  (function () {
    var roomMap = JSON.parse(roomMapJson);
    var activeTrack = 'all';
    var activeLevel = 'all';
    var activeRoom  = 'all';

    function applyFilters() {
      var sessions = document.querySelectorAll('li.sz-session');
      var visible = 0;
      sessions.forEach(function (el) {
        var id = el.getAttribute('data-sessionid');
        var trackOk = activeTrack === 'all' || el.classList.contains(activeTrack);
        var levelOk = activeLevel === 'all' || el.classList.contains(activeLevel);
        var roomOk  = activeRoom  === 'all' || roomMap[id] === activeRoom;
        var show = trackOk && levelOk && roomOk;
        el.classList.toggle('sz-session--filtered', !show);
        if (show) visible++;
      });
      var countEl = document.getElementById('session-count');
      if (countEl) {
        countEl.textContent = 'Showing ' + visible + ' of ' + sessions.length + ' sessions';
      }
    }

    function bindGroup(selector, stateKey) {
      document.querySelectorAll(selector).forEach(function (btn) {
        btn.addEventListener('click', function () {
          document.querySelectorAll(selector).forEach(function (b) {
            b.classList.remove('active');
            b.setAttribute('aria-pressed', 'false');
          });
          btn.classList.add('active');
          btn.setAttribute('aria-pressed', 'true');
          var val = btn.getAttribute('data-' + stateKey) || 'all';
          if (stateKey === 'track') activeTrack = val;
          else if (stateKey === 'level') activeLevel = val;
          else if (stateKey === 'room')  activeRoom  = val;
          applyFilters();
        });
      });
    }

    function makeCardsClickable() {
      document.querySelectorAll('li.sz-session').forEach(function (card) {
        // Add "View details" hint if not already added
        if (!card.querySelector('.sz-session__view-hint')) {
          var hint = document.createElement('span');
          hint.className = 'sz-session__view-hint';
          hint.innerHTML = 'View details &rarr;';
          card.appendChild(hint);
        }
        // Click anywhere on card (except speaker links) opens session modal
        card.addEventListener('click', function (e) {
          if (e.target.closest('a')) return; // let speaker links handle themselves
          var id = card.getAttribute('data-sessionid');
          if (id && window.sessionize) {
            window.sessionize.showModal('9q20ek5l', 'session', id);
          }
        });
      });
    }

    function watchForSessions() {
      var wrapper = document.getElementById('sessions-embed-wrapper');
      if (!wrapper) return;
      var observer = new MutationObserver(function (_, obs) {
        if (document.querySelectorAll('li.sz-session').length > 0) {
          obs.disconnect();
          applyFilters();
          makeCardsClickable();
        }
      });
      observer.observe(wrapper, { childList: true, subtree: true });
      if (document.querySelectorAll('li.sz-session').length > 0) {
        observer.disconnect();
        applyFilters();
        makeCardsClickable();
      }
    }

    document.addEventListener('DOMContentLoaded', function () {
      bindGroup('.filter-track', 'track');
      bindGroup('.filter-level', 'level');
      bindGroup('.filter-room',  'room');
      watchForSessions();
    });
  })();
</script>
