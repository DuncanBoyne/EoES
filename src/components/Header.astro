---
const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/about', label: 'About' },
  { href: '/why-attend', label: 'Why Attend' },
  { href: '/gallery-2026', label: '2026 Gallery' },
  { href: '/sessions', label: '2026 Sessions' },
  { href: '/speakers', label: '2026 Speakers' },
  {
    href: '/sponsors',
    label: 'Sponsors',
    children: [
      { href: '/sponsors', label: '2027 Sponsors' },
      { href: '/sponsors/2026', label: '2026 Sponsors' },
      { href: '/sponsorship', label: 'Become a Sponsor' },
    ],
  },
];

const currentPath = Astro.url.pathname;

function isActive(href: string): boolean {
  if (href === '/') return currentPath === '/';
  return currentPath === href || currentPath.startsWith(href + '/');
}

function isLinkActive(link: typeof navLinks[number]): boolean {
  return isActive(link.href) || Boolean(link.children?.some(child => isActive(child.href)));
}
---

<header class="site-header">
  <div class="color-bar" aria-hidden="true"></div>
  <div class="container nav-row">
    <a href="/" class="brand">
      <img src="/images/logo-hero.png" alt="" aria-hidden="true" />
      <span>EoES</span>
    </a>
    <nav aria-label="Main">
      {navLinks.map(link => (
        link.children ? (
          <div class:list={['nav-group', { active: isLinkActive(link) }]}>
            <a href={link.href} class:list={[{ active: isLinkActive(link) }]} aria-haspopup="true">
              {link.label}
              <svg viewBox="0 0 20 20" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path d="M5 8l5 5 5-5" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </a>
            <div class="nav-dropdown">
              {link.children.map(child => (
                <a href={child.href} class:list={[{ active: isActive(child.href) }]}>{child.label}</a>
              ))}
            </div>
          </div>
        ) : (
          <a href={link.href} class:list={[{ active: isActive(link.href) }]}>{link.label}</a>
        )
      ))}
    </nav>
    <button class="mobile-menu-btn" id="mobile-menu-btn" aria-label="Open navigation menu" aria-expanded="false" aria-controls="mobile-nav">
      <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path d="M4 6h16M4 12h16M4 18h16" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </button>
  </div>
  <nav class="mobile-nav" id="mobile-nav" aria-label="Mobile navigation">
    {navLinks.map(link => (
      link.children ? (
        <details class="mobile-nav-group" open={isLinkActive(link)}>
          <summary class:list={[{ active: isLinkActive(link) }]}>{link.label}</summary>
          <div>
            {link.children.map(child => (
              <a href={child.href} class:list={[{ active: isActive(child.href) }]}>{child.label}</a>
            ))}
          </div>
        </details>
      ) : (
        <a href={link.href} class:list={[{ active: isActive(link.href) }]}>{link.label}</a>
      )
    ))}
  </nav>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const nav = document.getElementById('mobile-nav');
  btn?.addEventListener('click', () => {
    const isOpen = nav?.classList.toggle('open');
    btn.setAttribute('aria-expanded', String(isOpen));
  });
</script>
